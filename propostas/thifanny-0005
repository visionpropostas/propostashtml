            if (selectContainer) {
                selectContainer.classList.add('opacity-0', 'pointer-events-none');
                setTimeout(() => { if(selectContainer) selectContainer.classList.add('hidden'); }, 300);
            }
        } else {
            if (bg) bg.style.transform = 'translateX(100%)';
            if (btnParcelado) {
                btnParcelado.classList.remove('text-gray-400');
                btnParcelado.classList.add('text-zinc-950');
            }
            if (btnPix) {
                btnPix.classList.remove('text-zinc-950');
                btnPix.classList.add('text-gray-400');
            }
            
            if (selectContainer) {
                selectContainer.classList.remove('hidden');
                setTimeout(() => { if(selectContainer) selectContainer.classList.remove('opacity-0', 'pointer-events-none'); }, 10);
            }
        }
        updatePrices();
    }

    function formatCurrency(value) {
        return Math.round(value).toLocaleString('pt-BR', { maximumFractionDigits: 0 });
    }

    function updatePrices() {
        const el1 = document.getElementById('price-opt1');
        const select = document.getElementById('installment-select');
        const visualPanel = document.getElementById('checkout-visual-panel');

        if (!el1 || !visualPanel) return;

        const scopeData = prices[currentScope];
        if (!scopeData) return;

        const basePriceVal = scopeData.pix;

        if (currentMode === 'avista') {
            const h1 = basePriceVal / 2; 
            const h2 = basePriceVal / 2; 

            el1.innerHTML = `
                <div class="flex flex-col items-center w-full animate-fade-in">
                    <span class="text-4xl md:text-5xl font-black text-gray-900 tracking-tight">R$ ${formatCurrency(basePriceVal)}</span>
                    <span class="text-[9px] font-bold text-emerald-600 uppercase tracking-widest mt-1">PIX • SEM JUROS</span>
                </div>
            `;

            // Painel Lateral Esquerdo: Fluxo de Cobrança PIX Estilizado
            visualPanel.innerHTML = `
                <div class="bg-gray-50 border border-gray-200 rounded-3xl p-6 shadow-sm space-y-4 animate-fade-in w-full">
                    <span class="text-[10px] font-extrabold text-zinc-400 uppercase tracking-widest block">ETAPAS DE FATURAMENTO (50/50):</span>
                    
                    <div class="relative pl-6 border-l-2 border-emerald-500 space-y-6">
                        <div class="relative">
                            <span class="absolute -left-[31px] top-0 w-4 h-4 rounded-full bg-emerald-500 border-4 border-white"></span>
                            <span class="text-[9px] font-extrabold text-emerald-600 uppercase block leading-none mb-1">Aprovação / Sinal (50%)</span>
                            <span class="text-lg font-black text-gray-900">R$ ${formatCurrency(h1)}</span>
                            <p class="text-[10px] text-gray-500 mt-1 font-semibold">Garante o faturamento imediato de materiais originais da Intelbras.</p>
                        </div>
                        <div class="relative">
                            <span class="absolute -left-[31px] top-0 w-4 h-4 rounded-full bg-brand-yellow border-4 border-white"></span>
                            <span class="text-[9px] font-extrabold text-brand-goldDark uppercase block leading-none mb-1">Entrega / Conclusão (50%)</span>
                            <span class="text-lg font-black text-gray-900">R$ ${formatCurrency(h2)}</span>
                            <p class="text-[10px] text-gray-500 mt-1 font-semibold">Faturado após a finalização de testes de foco e pareamento nos apps.</p>
                        </div>
                    </div>
                </div>
            `;

        } else {
            const inst = select ? parseInt(select.value) : 12;
            const totalWithRate = scopeData.rates[inst] || basePriceVal;
            const installmentValue = totalWithRate / inst;

            el1.innerHTML = `
                <div class="flex flex-col items-center w-full animate-fade-in">
                    <div class="flex items-baseline justify-center gap-1.5">
                        <span class="text-xl md:text-2xl font-black text-brand-yellow">${inst}x R$</span> 
                        <span class="text-4xl md:text-5xl font-black text-gray-900 tracking-tight">${formatCurrency(installmentValue)}</span>
                    </div>
                    <span class="text-[9px] text-zinc-400 font-bold uppercase tracking-widest mt-1">Total Parcelado: R$ ${formatCurrency(totalWithRate)}</span>
                </div>
            `;

            // Painel Lateral Esquerdo: Cartão de Crédito Dinâmico Premium
            visualPanel.innerHTML = `
                <div class="bg-gradient-to-br from-zinc-900 via-zinc-950 to-black text-white p-6 rounded-3xl shadow-glow-md border border-zinc-800 space-y-8 relative overflow-hidden aspect-[1.58/1] w-full max-w-sm animate-fade-in text-left">
                    <div class="absolute top-0 right-0 w-24 h-24 bg-brand-yellow/10 rounded-full blur-2xl pointer-events-none"></div>
                    
                    <div class="flex justify-between items-start">
                        <div class="flex flex-col leading-none">
                            <span class="text-[9px] text-brand-yellow uppercase tracking-widest font-bold">Cartão de Crédito</span>
                            <span class="text-sm font-black tracking-tight mt-1">VISION PAY</span>
                        </div>
                        <div class="w-8 h-8 rounded-full bg-white/5 border border-white/10 flex items-center justify-center">
                            <i data-lucide="credit-card" class="w-4 h-4 text-brand-yellow"></i>
                        </div>
                    </div>

                    <div class="space-y-1">
                        <span class="text-[10px] text-zinc-500 uppercase tracking-widest font-bold block">Valor da Parcela:</span>
                        <div class="flex items-baseline gap-1">
                            <span class="text-xs text-brand-yellow font-bold">${inst}x de</span>
                            <span class="text-2xl font-black tracking-tight">R$ ${formatCurrency(installmentValue)}</span>
                        </div>
                    </div>

                    <div class="flex justify-between items-end">
                        <div class="flex flex-col leading-none">
                            <span class="text-[8px] text-zinc-600 uppercase tracking-widest">Escritório</span>
                            <span class="text-xs font-bold tracking-wider mt-1 text-zinc-300">THIFANNY</span>
                        </div>
                        <span class="text-[9px] font-bold text-zinc-400 font-semibold">•••• 2026</span>
                    </div>
                </div>
            `;
        }
        
        updateWhatsAppLink();
        initIcons();
    }

    window.addEventListener("load", () => {
        setScope('combo-2tb');
        setPaymentMode('avista');
    });

    const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) entry.target.classList.add('active');
        });
    }, { threshold: 0.05 });
    document.querySelectorAll('.reveal').forEach(el => observer.observe(el));

    window.addEventListener('scroll', () => {
        const navbar = document.getElementById('navbar');
        const ctaFloat = document.getElementById('cta-float');
        
        if (window.scrollY > 50) {
            if(navbar) navbar.classList.add('shadow-md');
        } else {
            if(navbar) navbar.classList.remove('shadow-md');
        }

        if (window.scrollY > 400) {
            if(ctaFloat) {
                ctaFloat.classList.remove('hidden', 'opacity-0', 'translate-y-10', 'pointer-events-none');
                ctaFloat.classList.add('opacity-100', 'translate-y-0');
            }
        } else {
            if(ctaFloat) {
                ctaFloat.classList.add('opacity-0', 'translate-y-10', 'pointer-events-none');
            }
        }
    });

    document.addEventListener("DOMContentLoaded", function() {
        const video = document.getElementById("vision-video");
        const overlay = document.getElementById("unmute-overlay");
        if (video && overlay) {
            overlay.addEventListener("click", function(e) {
                e.stopPropagation(); 
                video.muted = false;
                video.loop = true; 
                video.currentTime = 0;
                video.play().catch(err => {
                    console.warn("Autoplay bloqueado.", err);
                });
                overlay.style.opacity = "0";
                setTimeout(() => { overlay.style.display = "none"; }, 500); 
            });
            video.addEventListener("click", function() {
                if (overlay.style.display === "none") {
                    if (video.paused) { video.play(); } else { video.pause(); }
                }
            });
        }

        const videoShorts = document.getElementById("demo-shorts-video");
        const overlayShorts = document.getElementById("unmute-overlay-shorts");
        if (videoShorts && overlayShorts) {
            overlayShorts.addEventListener("click", function(e) {
                e.stopPropagation(); 
                videoShorts.muted = false;
                videoShorts.loop = true; 
                videoShorts.currentTime = 0;
                videoShorts.play().catch(err => {
                    console.warn("Autoplay bloqueado.", err);
                });
                overlayShorts.style.opacity = "0";
                setTimeout(() => { overlayShorts.style.display = "none"; }, 500); 
            });
            videoShorts.addEventListener("click", function() {
                if (overlayShorts.style.display === "none") {
                    if (videoShorts.paused) { videoShorts.play(); } else { videoShorts.pause(); }
                }
            });
        }
    });
</script>
</body>
</html>
