    function toggleFaq(id) {
        const allItems = [1, 2, 3, 4];
        
        allItems.forEach(i => {
            const content = document.getElementById('faq-content-' + i);
            const arrow = document.getElementById('faq-arrow-' + i);
            if (!content || !arrow) return;

            if (i.toString() === id.toString()) {
                if (content.style.maxHeight === '0px' || content.classList.contains('max-h-0')) {
                    content.classList.remove('max-h-0');
                    content.style.maxHeight = content.scrollHeight + 'px';
                    arrow.style.transform = 'rotate(180deg)';
                } else {
                    content.style.maxHeight = '0px';
                    content.classList.add('max-h-0');
                    arrow.style.transform = 'rotate(0deg)';
                }
            } else {
                content.style.maxHeight = '0px';
                content.classList.add('max-h-0');
                arrow.style.transform = 'rotate(0deg)';
            }
        });
    }

    window.addEventListener("load", () => {
        setPaymentMode('avista');
        // Inicializa o primeiro FAQ como aberto de forma suave
        const firstContent = document.getElementById('faq-content-1');
        const firstArrow = document.getElementById('faq-arrow-1');
        if (firstContent && firstArrow) {
            firstContent.classList.remove('max-h-0');
            firstContent.style.maxHeight = firstContent.scrollHeight + 'px';
            firstArrow.style.transform = 'rotate(180deg)';
        }
    });

    const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) entry.target.classList.add('active');
        });
    }, { threshold: 0.05 });
    document.querySelectorAll('.reveal').forEach(el => observer.observe(el));

    window.addEventListener('scroll', () => {
        const navbar = document.getElementById('navbar');
        const ctaFloat = document.getElementById('cta-float');
        
        if (window.scrollY > 50) {
            if(navbar) navbar.classList.add('shadow-md');
        } else {
            if(navbar) navbar.classList.remove('shadow-md');
        }

        if (window.scrollY > 400) {
            if(ctaFloat) {
                ctaFloat.classList.remove('hidden', 'opacity-0', 'translate-y-10', 'pointer-events-none');
                ctaFloat.classList.add('opacity-100', 'translate-y-0');
            }
        } else {
            if(ctaFloat) {
                ctaFloat.classList.add('opacity-0', 'translate-y-10', 'pointer-events-none');
            }
        }
    });

    document.addEventListener("DOMContentLoaded", function() {
        function setupVideo(videoId, overlayId) {
            const video = document.getElementById(videoId);
            const overlay = document.getElementById(overlayId);
            if (video && overlay) {
                overlay.addEventListener("click", function(e) {
                    e.stopPropagation(); 
                    video.muted = false;
                    video.loop = true; 
                    video.currentTime = 0;
                    video.play().catch(err => {
                        console.warn("Autoplay bloqueado pelo navegador", err);
                    });
                    overlay.style.opacity = "0";
                    setTimeout(() => { overlay.style.display = "none"; }, 500); 

                    if (window.clarity) {
                        window.clarity("event", "Video_Assistido_" + videoId);
                    }
                });
                video.addEventListener("click", function() {
                    if (overlay.style.display === "none") {
                        if (video.paused) { video.play(); } else { video.pause(); }
                    }
                });
            }
        }

        setupVideo("vision-video", "unmute-overlay");
        setupVideo("demo-horizontal-video", "unmute-overlay-horizontal");
        setupVideo("demo-shorts-video", "unmute-overlay-shorts");
    });
</script>
