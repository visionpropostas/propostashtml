                iconBox.classList.add('bg-zinc-800', 'border-zinc-700');
                
                const iconSvg = iconBox.querySelector('svg') || iconBox.querySelector('i');
                if(iconSvg) {
                    iconSvg.classList.remove('text-brand-yellow');
                    iconSvg.classList.add('text-zinc-400');
                }
            }
            
            // Retira destaque do parágrafo
            const p = btn.querySelector('p');
            if(p) {
                p.classList.remove('text-zinc-400');
                p.classList.add('text-zinc-600');
