    // LÓGICA DO TOGGLE DE PAGAMENTO (PIX VS CARTÃO)
    let isPix = true;
    function togglePayment(toPix) {
        if(isPix === toPix) return; // Já está na aba certa
        isPix = toPix;

        const btnPix = document.getElementById('btn-pix');
        const btnCard = document.getElementById('btn-card');
        const pixBlock = document.getElementById('price-pix-block');
        const cardBlock = document.getElementById('price-card-block');

        // Fade out
        if(pixBlock) pixBlock.classList.add('opacity-0');
        if(cardBlock) cardBlock.classList.add('opacity-0');

        setTimeout(() => {
            if(isPix) {
                // Ativa estilo botão PIX
                if(btnPix) {
                    btnPix.classList.add('bg-brand-yellow', 'text-black');
                    btnPix.classList.remove('bg-transparent', 'text-gray-500');
                }
                // Desativa estilo botão Cartão
                if(btnCard) {
                    btnCard.classList.remove('bg-brand-yellow', 'text-black');
                    btnCard.classList.add('bg-transparent', 'text-gray-500', 'hover:text-gray-700');
                }

                // Mostra bloco PIX
                if(pixBlock) pixBlock.classList.remove('hidden');
                if(cardBlock) cardBlock.classList.add('hidden');
                
            } else {
                // Ativa estilo botão Cartão
                if(btnCard) {
                    btnCard.classList.add('bg-brand-yellow', 'text-black');
                    btnCard.classList.remove('bg-transparent', 'text-gray-500', 'hover:text-gray-700');
                }
                // Desativa estilo botão PIX
                if(btnPix) {
                    btnPix.classList.remove('bg-brand-yellow', 'text-black');
                    btnPix.classList.add('bg-transparent', 'text-gray-500');
                }

                // Mostra bloco Cartão
                if(pixBlock) pixBlock.classList.add('hidden');
                if(cardBlock) cardBlock.classList.remove('hidden');
            }

            lucide.createIcons();

            // Efeito de fade in 
            setTimeout(() => {
                if(pixBlock) pixBlock.classList.remove('opacity-0');
                if(cardBlock) cardBlock.classList.remove('opacity-0');
            }, 50);

        }, 300);

        // Registro no Clarity 
        if (window.clarity) window.clarity("event", isPix ? "Selecionou_PIX" : "Selecionou_Cartao");
    }

    // REVEAL ON SCROLL
    const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                entry.target.classList.add('active');
            }
        });
    }, { threshold: 0.1 });
    document.querySelectorAll('.reveal').forEach(el => observer.observe(el));

    // ANIMATE COUNTERS
    function animateCounter(el, target) {
        let current = 0;
        const increment = Math.ceil(target / 40) || 1;
        const interval = setInterval(() => {
            current = Math.min(current + increment, target);
            el.textContent = current;
            if (current === target) clearInterval(interval);
        }, 40);
    }
    const counterObserver = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                const el = entry.target;
                const target = parseInt(el.getAttribute('data-target'));
                animateCounter(el, target);
                counterObserver.unobserve(el);
            }
        });
    }, { threshold: 0.5 });
    document.querySelectorAll('[data-target]').forEach(el => counterObserver.observe(el));

    // ACCORDION
    function toggleAccordion(btn) {
        const item = btn.parentElement;
        const isOpen = item.classList.contains('open');
        document.querySelectorAll('.accordion-item').forEach(i => i.classList.remove('open'));
        if (!isOpen) item.classList.add('open');
        lucide.createIcons();
    }

    // NAVBAR E CTA SCROLL
    window.addEventListener('scroll', () => {
        const navbar = document.getElementById('navbar');
        const ctaFloat = document.getElementById('cta-float');
        
        if (window.scrollY > 50) {
            if(navbar) navbar.classList.add('shadow-md');
        } else {
            if(navbar) navbar.classList.remove('shadow-md');
        }

        if (window.scrollY > 400) {
            if(ctaFloat) {
                ctaFloat.classList.remove('hidden', 'opacity-0', 'translate-y-10', 'pointer-events-none');
                ctaFloat.classList.add('opacity-100', 'translate-y-0');
            }
        } else {
            if(ctaFloat) {
                ctaFloat.classList.remove('opacity-100', 'translate-y-0');
                ctaFloat.classList.add('opacity-0', 'translate-y-10', 'pointer-events-none');
            }
        }
    });

    // VIDEO UNMUTE
    document.addEventListener("DOMContentLoaded", function() {
        function setupVideo(videoId, overlayId) {
            const video = document.getElementById(videoId);
            const overlay = document.getElementById(overlayId);
            if (video && overlay) {
                overlay.addEventListener("click", function(e) {
                    e.stopPropagation(); 
                    video.muted = false;
                    video.loop = false; 
                    video.currentTime = 0;
                    video.play();
                    overlay.style.opacity = "0";
                    setTimeout(() => { overlay.style.display = "none"; }, 500); 

                    // Rastreamento Clarity - Vídeo Assistido
                    if (window.clarity) {
                        window.clarity("event", "Video_Assistido_" + videoId);
                    }
                });
                video.addEventListener("click", function() {
                    if (overlay.style.display === "none") {
                        if (video.paused) { video.play(); } else { video.pause(); }
                    }
                });
            }
        }

        setupVideo("vision-video", "unmute-overlay");
    });
</script>
