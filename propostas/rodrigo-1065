<script>
    // PREÇOS OFICIAIS DO ORÇAMENTO ATUALIZADO
    const basePrice = 14410; // Valor PIX À Vista
    
    // Tabela oficial de repasse de taxas da máquina (Markup reverso)
    const rates = {
        1: 0.0420, 
        2: 0.0609, 
        3: 0.0701, 
        4: 0.0791, 
        5: 0.0880, 
        6: 0.0967,
        7: 0.1259, 
        8: 0.1342, 
        9: 0.1425, 
        10: 0.1506, 
        11: 0.1587, 
        12: 0.1666
    };
    
    let currentMode = 'parcelado';

    document.addEventListener("DOMContentLoaded", () => {
        lucide.createIcons();
        setPaymentMode('parcelado'); // Inicializa no modo parcelado de forma padrão
        
        // Listener otimizado para o input de senha
        const pwdInput = document.getElementById('password-input');
        if (pwdInput) {
            pwdInput.addEventListener('keypress', function (e) {
                if (e.key === 'Enter') {
                    e.preventDefault();
                    checkPassword();
                }
            });
        }
    });

    // Visibilidade de Senha Amigável
    function togglePasswordVisibility() {
        const input = document.getElementById('password-input');
        const icon = document.getElementById('eye-icon');
        if (input && icon) {
            if (input.type === 'password') {
                input.type = 'text';
                icon.setAttribute('data-lucide', 'eye-off');
            } else {
                input.type = 'password';
                icon.setAttribute('data-lucide', 'eye');
            }
            lucide.createIcons();
        }
    }

    function setPaymentMode(mode) {
        currentMode = mode;
        const bg = document.getElementById('toggle-bg');
        const btnAvista = document.getElementById('btn-avista');
        const btnParcelado = document.getElementById('btn-parcelado');
        const selectContainer = document.getElementById('installment-container');

        if (!bg || !btnAvista || !btnParcelado || !selectContainer) return;

        if (mode === 'avista') {
            bg.style.transform = 'translateX(0)';
            btnAvista.classList.remove('text-gray-500');
            btnAvista.classList.add('text-gray-900');
            btnParcelado.classList.remove('text-gray-900');
            btnParcelado.classList.add('text-gray-500');
            
            selectContainer.classList.add('opacity-0', 'pointer-events-none');
            setTimeout(() => selectContainer.classList.add('hidden'), 300);
        } else {
            bg.style.transform = 'translateX(100%)';
            btnParcelado.classList.remove('text-gray-500');
            btnParcelado.classList.add('text-gray-900');
            btnAvista.classList.remove('text-gray-900');
            btnAvista.classList.add('text-gray-500');
            
            selectContainer.classList.remove('hidden');
            setTimeout(() => selectContainer.classList.remove('opacity-0', 'pointer-events-none'), 10);
        }
        updatePrices();
    }

    function updatePrices() {
        const elPrice = document.getElementById('price-box');
        const elSub = document.getElementById('subtext-box');
        const select = document.getElementById('installment-select');

        if (!elPrice || !elSub || !select) return;

        if (currentMode === 'avista') {
            elPrice.innerHTML = `<span class="text-5xl font-extrabold text-gray-900">R$ ${basePrice.toLocaleString('pt-BR')}</span>`;
            elSub.innerHTML = '<strong>Condição Comercial:</strong> 50% de sinal faturado no fechamento e o restante na entrega do sistema.';
        } else {
            const inst = parseInt(select.value) || 12;
            const rate = rates[inst];
            
            // Fórmula do cálculo de parcelamento com repasse de taxa de máquina (markup reverso)
            const cardTotal = basePrice / (1 - rate);
            const instValue = cardTotal / inst;

            elPrice.innerHTML = `<span class="text-2xl font-bold text-brand-yellow mb-1">${inst}x</span> <span class="text-5xl font-extrabold text-gray-900">R$ ${instValue.toLocaleString('pt-BR', {minimumFractionDigits: 2, maximumFractionDigits: 2})}</span>`;
            elSub.innerHTML = `Total Financiado: R$ ${cardTotal.toLocaleString('pt-BR', {minimumFractionDigits: 2, maximumFractionDigits: 2})} (Transação via Cartão de Crédito)`;
        }
    }

    // LOCK SCREEN + STATICFORMS TRACKING
    function checkPassword() {
        const inputElement = document.getElementById('password-input');
        if (!inputElement) return;

        const input = inputElement.value.trim().toUpperCase();
        const errorMsg = document.getElementById('error-msg');
        
        // Verificação amigável e desprovida de erros para o Rodrigo
        if (input === 'RODRIGO2026' || input === 'RODRIGO' || input === 'VISION') {
            const lockScreen = document.getElementById('lock-screen');
            lockScreen.style.opacity = '0';

            const video = document.getElementById("vision-video");
            if (video && video.paused) {
                video.muted = true;
                video.play().catch(e => { console.log('Autoplay não liberado pelas políticas de mídia.'); });
            }

            // Envio silencioso do Log de Acesso
            fetch('https://api.staticforms.dev/submit', {
                method: 'POST',
                headers: { 
                    'Content-Type': 'application/json',
                    'Accept': 'application/json'
                },
                body: JSON.stringify({
                    accessKey: "sf_077ej49gjha153gk3m6ceecf", 
                    apiKey: "sf_077ej49gjha153gk3m6ceecf", 
                    subject: "🚨 ALERTA: Proposta Vision Acessada por Rodrigo (Banho e Tosa)",
                    name: "Vision Business Logger",
                    email: "diretoria@visionsp.com.br",
                    message: `O Rodrigo acabou de abrir o projeto técnico!\n\n🏢 Imóvel: Banho e Tosa 80m² Interno (Perímetro 10x10.5m)\n🔑 Chave Utilizada: ${input}\n🕒 Horário Local: ${new Date().toLocaleString('pt-BR')}`
                })
            }).catch(error => console.log('Log mantido em cache local.'));

            setTimeout(() => { 
                lockScreen.style.display = 'none'; 
                const htmlRoot = document.getElementById('html-root');
                if (htmlRoot) {
                    htmlRoot.classList.remove('overflow-hidden', 'h-screen');
                    htmlRoot.classList.add('overflow-x-hidden');
                }
                document.body.classList.remove('overflow-hidden', 'h-screen');
            }, 700);
        } else {
            errorMsg.classList.remove('hidden');
            inputElement.style.borderColor = 'rgba(239,68,68,0.5)';
            setTimeout(() => {
                errorMsg.classList.add('hidden');
                inputElement.style.borderColor = '';
            }, 3000);
        }
    }

    // REVEAL ON SCROLL
    const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                entry.target.classList.add('active');
            }
        });
    }, { threshold: 0.1 });
    document.querySelectorAll('.reveal').forEach(el => observer.observe(el));

    // COUNTERS
    function animateCounter(el, target) {
        let current = 0;
        const increment = Math.ceil(target / 40) > 0 ? Math.ceil(target / 40) : 1; 
        const interval = setInterval(() => {
            current = Math.min(current + increment, target);
            el.textContent = current + (el.textContent.includes('%') ? '%' : ''); 
            if (target === 100) el.textContent = current + '%';
            if (current === target) clearInterval(interval);
        }, 30);
    }
    
    const counterObserver = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                const el = entry.target;
                const target = parseInt(el.getAttribute('data-target'));
                if (!isNaN(target)) {
                     el.textContent = '0';
                     animateCounter(el, target);
                }
                counterObserver.unobserve(el);
            }
        });
    }, { threshold: 0.5 });
    document.querySelectorAll('[data-target]').forEach(el => counterObserver.observe(el));

    // NAVBAR & SCROLL BEHAVIOR
    window.addEventListener('scroll', () => {
        const navbar = document.getElementById('navbar');
        const ctaFloat = document.getElementById('cta-float');
        if (!navbar || !ctaFloat) return;
        
        if (window.scrollY > 50) {
            navbar.classList.add('shadow-md', 'py-1');
        } else {
            navbar.classList.remove('shadow-md', 'py-1');
        }

        if (window.scrollY > 400) {
            ctaFloat.classList.remove('opacity-0', 'translate-y-10', 'pointer-events-none');
            ctaFloat.classList.add('opacity-100', 'translate-y-0');
        } else {
            ctaFloat.classList.add('opacity-0', 'translate-y-10', 'pointer-events-none');
            ctaFloat.classList.remove('opacity-100', 'translate-y-0');
        }
    });

    // ACCORDION
    function toggleAccordion(btn) {
        const item = btn.parentElement;
        if (!item) return;
        const isOpen = item.classList.contains('open');
        document.querySelectorAll('.accordion-item').forEach(i => i.classList.remove('open'));
        if (!isOpen) {
            item.classList.add('open');
        }
    }
    
    // VIDEO UNMUTE & PLAY-PAUSE (HERO AND HD VIDEOS)
    document.addEventListener("DOMContentLoaded", function() {
        // Hero Video
        const heroVideo = document.getElementById("vision-video");
        const heroOverlay = document.getElementById("unmute-overlay");
        
        if (heroVideo && heroOverlay) {
            heroOverlay.addEventListener("click", function(e) {
                e.stopPropagation(); 
                heroVideo.muted = false;
                heroVideo.loop = false; 
                heroVideo.currentTime = 0;
                heroVideo.play().catch(err => { console.log("Permissão de mídia restrita pelo browser:", err); });
                heroOverlay.style.opacity = "0";
                setTimeout(() => { heroOverlay.style.display = "none"; }, 500); 
            });

            heroVideo.addEventListener("click", function() {
                if (heroOverlay.style.display === "none") {
                    if (heroVideo.paused) { 
                        heroVideo.play(); 
                    } else { 
                        heroVideo.pause(); 
                    }
                }
            });
        }

        // HD Video (WD Purple Explainer)
        const hdVideo = document.getElementById("hd-video");
        const hdOverlay = document.getElementById("unmute-overlay-hd");

        if (hdVideo && hdOverlay) {
            hdOverlay.addEventListener("click", function(e) {
                e.stopPropagation();
                hdVideo.muted = false;
                hdVideo.loop = false;
                hdVideo.currentTime = 0;
                hdVideo.play().catch(err => { console.log("Permissão de mídia restrita pelo browser:", err); });
                hdOverlay.style.opacity = "0";
                setTimeout(() => { hdOverlay.style.display = "none"; }, 500);
            });

            hdVideo.addEventListener("click", function() {
                if (hdOverlay.style.display === "none") {
                    if (hdVideo.paused) {
                        hdVideo.play();
                    } else {
                        hdVideo.pause();
                    }
                }
            });
        }
    });
</script>
