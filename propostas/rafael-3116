            document.getElementById('password-input').style.borderColor = 'rgba(239,68,68,0.5)';
            setTimeout(() => {
                errorMsg.classList.add('hidden');
                document.getElementById('password-input').style.borderColor = '';
            }, 3000);
        }
    }

    // Permitir submeter com a tecla Enter
    document.getElementById('password-input').addEventListener('keypress', function(e) {
        if (e.key === 'Enter') {
            checkPassword();
        }
    });

    // REVEAL ON SCROLL
    const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                entry.target.classList.add('active');
            }
        });
    }, { threshold: 0.1 });
    document.querySelectorAll('.reveal').forEach(el => observer.observe(el));

    // ANIMATE COUNTERS
    function animateCounter(el, target) {
        let current = 0;
        const increment = Math.ceil(target / 40) || 1;
        const interval = setInterval(() => {
            current = Math.min(current + increment, target);
            el.textContent = current;
            if (current === target) clearInterval(interval);
        }, 40);
    }
    const counterObserver = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                const el = entry.target;
                const target = parseInt(el.getAttribute('data-target'));
                animateCounter(el, target);
                counterObserver.unobserve(el);
            }
        });
    }, { threshold: 0.5 });
    document.querySelectorAll('[data-target]').forEach(el => counterObserver.observe(el));

    // ACCORDION
    function toggleAccordion(btn) {
        const item = btn.parentElement;
        const isOpen = item.classList.contains('open');
        document.querySelectorAll('.accordion-item').forEach(i => i.classList.remove('open'));
        if (!isOpen) item.classList.add('open');
        lucide.createIcons();
    }

    // LÓGICA DO CHECKBOX MONITORAMENTO 24H
    let monitoringActive = false;
    function toggleMonitoring() {
        monitoringActive = !monitoringActive;
        const icon = document.getElementById('mon-check-icon');
        const box = document.getElementById('mon-checkbox');
        const container = document.getElementById('monthly-fee-container');

        if(monitoringActive) {
            icon.classList.remove('opacity-0');
            box.classList.remove('bg-white', 'border-gray-300');
            box.classList.add('bg-brand-yellow', 'border-brand-yellow');
            container.classList.remove('hidden');
            
            // Evento para o Clarity
            if(window.clarity) window.clarity('event', 'Selecionou_Monitoramento24h');
        } else {
            icon.classList.add('opacity-0');
            box.classList.add('bg-white', 'border-gray-300');
            box.classList.remove('bg-brand-yellow', 'border-brand-yellow');
            container.classList.add('hidden');
        }
    }

    // NAVBAR E CTA SCROLL
    window.addEventListener('scroll', () => {
        const navbar = document.getElementById('navbar');
        const ctaFloat = document.getElementById('cta-float');
        
        if (window.scrollY > 50) {
            navbar.classList.add('shadow-md');
        } else {
            navbar.classList.remove('shadow-md');
        }

        if (window.scrollY > 400) {
            ctaFloat.classList.remove('hidden');
        } else {
            ctaFloat.classList.add('hidden');
        }
    });

    // VIDEO UNMUTE LÓGICA DO VÍDEO DO HERO
    document.addEventListener("DOMContentLoaded", function() {
        function setupVideo(videoId, overlayId) {
            const video = document.getElementById(videoId);
            const overlay = document.getElementById(overlayId);
            if (video && overlay) {
                overlay.addEventListener("click", function(e) {
                    e.stopPropagation(); 
                    video.muted = false;
                    video.loop = false; 
                    video.currentTime = 0;
                    video.play();
                    overlay.style.opacity = "0";
                    setTimeout(() => { overlay.style.display = "none"; }, 500); 

                    // Rastreamento Clarity - Vídeo Assistido
                    if (window.clarity) {
                        window.clarity("event", "Video_Assistido");
                    }
                });
                video.addEventListener("click", function() {
                    if (overlay.style.display === "none") {
                        if (video.paused) { video.play(); } else { video.pause(); }
                    }
                });
            }
        }

        setupVideo("vision-video", "unmute-overlay");
    });
</script>
</body>
</html>
