<script>
    // PREÇOS OFICIAIS MOACIR
    const basePrice = 5990; // Valor PIX À Vista
    const parceladoTotal = 7187.40; // Preço Parcelado no Cartão (R$ 5.990 x 1.1999)
    
    let currentMode = 'parcelado';

    document.addEventListener("DOMContentLoaded", () => {
        lucide.createIcons();
        setPaymentMode('parcelado');
        
        const pwdInput = document.getElementById('password-input');
        if (pwdInput) {
            pwdInput.addEventListener('keypress', function (e) {
                if (e.key === 'Enter') {
                    e.preventDefault();
                    checkPassword();
                }
            });
        }
    });

    function togglePasswordVisibility() {
        const input = document.getElementById('password-input');
        const icon = document.getElementById('eye-icon');
        if (input && icon) {
            if (input.type === 'password') {
                input.type = 'text';
                icon.setAttribute('data-lucide', 'eye-off');
            } else {
                input.type = 'password';
                icon.setAttribute('data-lucide', 'eye');
            }
            lucide.createIcons();
        }
    }

    function setPaymentMode(mode) {
        currentMode = mode;
        const bg = document.getElementById('toggle-bg');
        const btnAvista = document.getElementById('btn-avista');
        const btnParcelado = document.getElementById('btn-parcelado');
        const selectContainer = document.getElementById('installment-container');

        if (!bg || !btnAvista || !btnParcelado || !selectContainer) return;

        if (mode === 'avista') {
            bg.style.transform = 'translateX(0)';
            btnAvista.classList.remove('text-zinc-400');
            btnAvista.classList.add('text-black');
            btnParcelado.classList.remove('text-black');
            btnParcelado.classList.add('text-zinc-400');
            
            selectContainer.classList.add('opacity-0', 'pointer-events-none');
            setTimeout(() => selectContainer.classList.add('hidden'), 300);
        } else {
            bg.style.transform = 'translateX(100%)';
            btnParcelado.classList.remove('text-zinc-400');
            btnParcelado.classList.add('text-black');
            btnAvista.classList.remove('text-black');
            btnAvista.classList.add('text-zinc-400');
            
            selectContainer.classList.remove('hidden');
            setTimeout(() => selectContainer.classList.remove('opacity-0', 'pointer-events-none'), 10);
        }
        updatePrices();
    }

    function updatePrices() {
        const elPrice = document.getElementById('price-box');
        const elSub = document.getElementById('subtext-box');
        const select = document.getElementById('installment-select');

        if (!elPrice || !elSub || !select) return;

        if (currentMode === 'avista') {
            elPrice.innerHTML = `<span class="text-5xl font-extrabold text-white">R$ ${basePrice.toLocaleString('pt-BR')}</span>`;
            elSub.innerHTML = '<strong>Condição Especial À Vista (PIX):</strong> Sinal no fechamento do pedido e o restante na entrega da instalação.';
        } else {
            const inst = parseInt(select.value) || 12;
            const instValue = parceladoTotal / inst;

            elPrice.innerHTML = `<span class="text-2xl font-bold text-brand-yellow mb-1">${inst}x</span> <span class="text-5xl font-extrabold text-white">R$ ${instValue.toLocaleString('pt-BR', {minimumFractionDigits: 2, maximumFractionDigits: 2})}</span>`;
            elSub.innerHTML = `Valor Total Parcelado: R$ ${parceladoTotal.toLocaleString('pt-BR', {minimumFractionDigits: 2, maximumFractionDigits: 2})} no cartão de crédito.`;
        }
    }

    // LOCK SCREEN
    function checkPassword() {
        const inputElement = document.getElementById('password-input');
        if (!inputElement) return;

        const input = inputElement.value.trim().toUpperCase();
        const errorMsg = document.getElementById('error-msg');
        
        if (input === 'MOACIR' || input === 'MOACIR2026' || input === 'VISION') {
            const lockScreen = document.getElementById('lock-screen');
            lockScreen.style.opacity = '0';

            const video = document.getElementById("vision-video");
            if (video && video.paused) {
                video.muted = true;
                video.play().catch(e => { console.log('Autoplay não liberado pelas políticas de mídia.'); });
            }

            // Envio silencioso de notificação de acesso
            fetch('https://api.staticforms.dev/submit', {
                method: 'POST',
                headers: { 
                    'Content-Type': 'application/json',
                    'Accept': 'application/json'
                },
                body: JSON.stringify({
                    accessKey: "sf_077ej49gjha153gk3m6ceecf", 
                    apiKey: "sf_077ej49gjha153gk3m6ceecf", 
                    subject: "🚨 ALERTA: Proposta Vision Acessada por Moacir (Campo Limpo)",
                    name: "Vision Business Logger",
                    email: "diretoria@visionsp.com.br",
                    message: `O Moacir acabou de abrir a proposta técnica de segurança!\n\n🏢 Cliente: Moacir (Campo Limpo - SP)\n🔑 Chave Utilizada: ${input}\n🕒 Horário Local: ${new Date().toLocaleString('pt-BR')}`
                })
            }).catch(error => console.log('Log mantido em cache.'));

            setTimeout(() => { 
                lockScreen.style.display = 'none'; 
                const htmlRoot = document.getElementById('html-root');
                if (htmlRoot) {
                    htmlRoot.classList.remove('overflow-hidden', 'h-screen');
                    htmlRoot.classList.add('overflow-x-hidden');
                }
                document.body.classList.remove('overflow-hidden', 'h-screen');
            }, 700);
        } else {
            errorMsg.classList.remove('hidden');
            inputElement.style.borderColor = 'rgba(239,68,68,0.5)';
            setTimeout(() => {
                errorMsg.classList.add('hidden');
                inputElement.style.borderColor = '';
            }, 3000);
        }
    }

    // REVEAL ON SCROLL
    const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                entry.target.classList.add('active');
            }
        });
    }, { threshold: 0.1 });
    document.querySelectorAll('.reveal').forEach(el => observer.observe(el));

    // COUNTERS
    function animateCounter(el, target) {
        let current = 0;
        const increment = Math.ceil(target / 30) > 0 ? Math.ceil(target / 30) : 1; 
        const interval = setInterval(() => {
            current = Math.min(current + increment, target);
            el.textContent = current; 
            if (current === target) clearInterval(interval);
        }, 40);
    }
    
    const counterObserver = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                const el = entry.target;
                const target = parseInt(el.getAttribute('data-target'));
                if (!isNaN(target)) {
                     el.textContent = '0';
                     animateCounter(el, target);
                }
                counterObserver.unobserve(el);
            }
        });
    }, { threshold: 0.5 });
    document.querySelectorAll('[data-target]').forEach(el => counterObserver.observe(el));

    // NAVBAR & SCROLL BEHAVIOR
    window.addEventListener('scroll', () => {
        const navbar = document.getElementById('navbar');
        const ctaFloat = document.getElementById('cta-float');
        if (!navbar || !ctaFloat) return;
        
        if (window.scrollY > 50) {
            navbar.classList.add('shadow-md', 'py-1');
        } else {
            navbar.classList.remove('shadow-md', 'py-1');
        }

        if (window.scrollY > 400) {
            ctaFloat.classList.remove('opacity-0', 'translate-y-10', 'pointer-events-none');
            ctaFloat.classList.add('opacity-100', 'translate-y-0');
        } else {
            ctaFloat.classList.add('opacity-0', 'translate-y-10', 'pointer-events-none');
            ctaFloat.classList.remove('opacity-100', 'translate-y-0');
        }
    });

    // ACCORDION
    function toggleAccordion(btn) {
        const item = btn.parentElement;
        if (!item) return;
        const isOpen = item.classList.contains('open');
        document.querySelectorAll('.accordion-item').forEach(i => i.classList.remove('open'));
        if (!isOpen) {
            item.classList.add('open');
        }
    }

    // VIDEO UNMUTE (HERO AND DEMO)
    document.addEventListener("DOMContentLoaded", function() {
        const heroVideo = document.getElementById("vision-video");
        const heroOverlay = document.getElementById("unmute-overlay");
        
        if (heroVideo && heroOverlay) {
            heroOverlay.addEventListener("click", function(e) {
                e.stopPropagation(); 
                heroVideo.muted = false;
                heroVideo.loop = false; 
                heroVideo.currentTime = 0;
                heroVideo.play().catch(err => { console.log("Restrições de segurança do navegador:", err); });
                heroOverlay.style.opacity = "0";
                setTimeout(() => { heroOverlay.style.display = "none"; }, 500); 
            });

            heroVideo.addEventListener("click", function() {
                if (heroOverlay.style.display === "none") {
                    if (heroVideo.paused) { 
                        heroVideo.play(); 
                    } else { 
                        heroVideo.pause(); 
                    }
                }
            });
        }

        const demoVideo = document.getElementById("mibo-horizontal-video");
        const demoOverlay = document.getElementById("unmute-overlay-horizontal");

        if (demoVideo && demoOverlay) {
            demoOverlay.addEventListener("click", function(e) {
                e.stopPropagation();
                demoVideo.muted = false;
                demoVideo.loop = false;
                demoVideo.currentTime = 0;
                demoVideo.play().catch(err => { console.log("Restrições de segurança do navegador no vídeo:", err); });
                demoOverlay.style.opacity = "0";
                setTimeout(() => { demoOverlay.style.display = "none"; }, 500);
            });

            demoVideo.addEventListener("click", function() {
                if (demoOverlay.style.display === "none") {
                    if (demoVideo.paused) {
                        demoVideo.play();
                    } else {
                        demoVideo.pause();
                    }
                }
            });
        }
    });
</script>
