<script>
    // INIT LUCIDE ICONS
    lucide.createIcons();

    // LÓGICA DO TOGGLE DE PAGAMENTO (PIX VS CARTÃO)
    let isPix = true;
    function togglePayment(toPix) {
        if(isPix === toPix) return; // Já está na aba certa
        isPix = toPix;

        const btnPix = document.getElementById('btn-pix');
        const btnCard = document.getElementById('btn-card');
        const pixBlock = document.getElementById('price-pix-block');
        const cardBlock = document.getElementById('price-card-block');

        // Fade out
        pixBlock.classList.add('opacity-0');
        cardBlock.classList.add('opacity-0');

        setTimeout(() => {
            if(isPix) {
                // Ativa estilo botão PIX
                btnPix.classList.add('bg-brand-yellow', 'text-black');
                btnPix.classList.remove('bg-transparent', 'text-gray-500');
                // Desativa estilo botão Cartão
                btnCard.classList.remove('bg-brand-yellow', 'text-black');
                btnCard.classList.add('bg-transparent', 'text-gray-500', 'hover:text-gray-700');

                // Mostra bloco PIX
                pixBlock.classList.remove('hidden');
                cardBlock.classList.add('hidden');
                
            } else {
                // Ativa estilo botão Cartão
                btnCard.classList.add('bg-brand-yellow', 'text-black');
                btnCard.classList.remove('bg-transparent', 'text-gray-500', 'hover:text-gray-700');
                // Desativa estilo botão PIX
                btnPix.classList.remove('bg-brand-yellow', 'text-black');
                btnPix.classList.add('bg-transparent', 'text-gray-500');

                // Mostra bloco Cartão
                pixBlock.classList.add('hidden');
                cardBlock.classList.remove('hidden');
            }

            lucide.createIcons();

            // Efeito de fade in 
            setTimeout(() => {
                pixBlock.classList.remove('opacity-0');
                cardBlock.classList.remove('opacity-0');
            }, 50);

        }, 300);

        // Registro no Clarity 
        if (window.clarity) window.clarity("event", isPix ? "Selecionou_PIX" : "Selecionou_Cartao");
    }

    // LOCK SCREEN + FORMSUBMIT
    function checkPassword() {
        const input = document.getElementById('password-input').value;
        const errorMsg = document.getElementById('error-msg');
        
        if (input.toUpperCase() === 'LETICIA2026' || input.toUpperCase() === 'VISION') {
            const lockScreen = document.getElementById('lock-screen');
            lockScreen.style.opacity = '0';

            // Start Video Se houver
            const video = document.getElementById("vision-video");
            if (video && video.paused) {
                video.muted = true;
                video.play().catch(e => {});
            }

            // --- CLARITY API TRACKING ---
            if (window.clarity) {
                window.clarity("consent");
                window.clarity("identify", "leticia-newcont", undefined, undefined, "Letícia (New Cont Novo)");
                window.clarity("set", "Proposta", "Projeto_Acesso_Leticia");
                window.clarity("event", "Proposta_Desbloqueada");
            }

            // Envio silencioso do alerta de acesso
            fetch('https://api.staticforms.dev/submit', {
                method: 'POST',
                headers: { 
                    'Content-Type': 'application/json',
                    'Accept': 'application/json'
                },
                body: JSON.stringify({
                    accessKey: "sf_077ej49gjha153gk3m6ceecf",
                    subject: "🚨 ALERTA: Proposta Acessada (Letícia - New Cont)",
                    name: "Sistema Vision",
                    email: "diretoria@visionsp.com.br",
                    message: `A cliente Letícia abriu a proposta do prédio novo (R$ 5.790)!\n\n👤 Cliente: Letícia (New Cont - Santo André)\n🔑 Senha Utilizada: ${input}\n🕒 Horário: ${new Date().toLocaleString('pt-BR')}`
                })
            }).catch(error => console.log('Log de acesso registrado.'));

            setTimeout(() => { 
                lockScreen.style.display = 'none'; 
                const htmlRoot = document.getElementById('html-root');
                if(htmlRoot) {
                    htmlRoot.classList.remove('overflow-hidden', 'h-screen');
                    htmlRoot.classList.add('overflow-x-hidden');
                }
                document.body.classList.remove('overflow-hidden', 'h-screen');
            }, 700);
        } else {
            errorMsg.classList.remove('hidden');
            document.getElementById('password-input').style.borderColor = 'rgba(239,68,68,0.5)';
            setTimeout(() => {
                errorMsg.classList.add('hidden');
                document.getElementById('password-input').style.borderColor = '';
            }, 3000);
        }
    }

    // Permitir submeter com a tecla Enter
    document.getElementById('password-input').addEventListener('keypress', function(e) {
        if (e.key === 'Enter') {
            checkPassword();
        }
    });

    // REVEAL ON SCROLL
    const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                entry.target.classList.add('active');
            }
        });
    }, { threshold: 0.1 });
    document.querySelectorAll('.reveal').forEach(el => observer.observe(el));

    // ANIMATE COUNTERS
    function animateCounter(el, target) {
        let current = 0;
        const increment = Math.ceil(target / 40);
        const interval = setInterval(() => {
            current = Math.min(current + increment, target);
            el.textContent = current;
            if (current === target) clearInterval(interval);
        }, 40);
    }
    const counterObserver = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                const el = entry.target;
                const target = parseInt(el.getAttribute('data-target'));
                animateCounter(el, target);
                counterObserver.unobserve(el);
            }
        });
    }, { threshold: 0.5 });
    document.querySelectorAll('[data-target]').forEach(el => counterObserver.observe(el));

    // ACCORDION
    function toggleAccordion(btn) {
        const item = btn.parentElement;
        const isOpen = item.classList.contains('open');
        document.querySelectorAll('.accordion-item').forEach(i => i.classList.remove('open'));
        if (!isOpen) item.classList.add('open');
        lucide.createIcons();
    }

    // NAVBAR E CTA SCROLL
    window.addEventListener('scroll', () => {
        const navbar = document.getElementById('navbar');
        const ctaFloat = document.getElementById('cta-float');
        
        if (window.scrollY > 50) {
            navbar.classList.add('shadow-md');
        } else {
            navbar.classList.remove('shadow-md');
        }

        if (window.scrollY > 400) {
            ctaFloat.classList.remove('hidden');
        } else {
            ctaFloat.classList.add('hidden');
        }
    });

    // VIDEO UNMUTE
    document.addEventListener("DOMContentLoaded", function() {
        const videoHero = document.getElementById("vision-video");
        const overlayHero = document.getElementById("unmute-overlay");
        
        if (videoHero && overlayHero) {
            overlayHero.addEventListener("click", function(e) {
                e.stopPropagation(); 
                videoHero.muted = false;
                videoHero.loop = false; 
                videoHero.currentTime = 0;
                videoHero.play();
                overlayHero.style.opacity = "0";
                setTimeout(() => { overlayHero.style.display = "none"; }, 500); 
                
                if (window.clarity) {
                    window.clarity("event", "Video_Assistido");
                }
            });

            videoHero.addEventListener("click", function() {
                if (overlayHero.style.display === "none") {
                    if (videoHero.paused) { videoHero.play(); } else { videoHero.pause(); }
                }
            });
        }
    });
</script>
