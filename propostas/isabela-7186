    window.addEventListener("load", () => {
        setPaymentMode('avista');
    });

    const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) entry.target.classList.add('active');
        });
    }, { threshold: 0.05 });
    document.querySelectorAll('.reveal').forEach(el => observer.observe(el));

    window.addEventListener('scroll', () => {
        const winScroll = document.documentElement.scrollTop || document.body.scrollTop;
        const height = document.documentElement.scrollHeight - document.documentElement.clientHeight;
        const scrolled = (winScroll / height) * 100;
        const progressBar = document.getElementById("progress-bar");
        if(progressBar) {
            progressBar.style.width = scrolled + "%";
        }

        const navbar = document.getElementById('navbar');
        if (window.scrollY > 50) {
            if(navbar) navbar.classList.add('shadow-md');
        } else {
            if(navbar) navbar.classList.remove('shadow-md');
        }
    });

    document.addEventListener("DOMContentLoaded", function() {
        function setupVideo(videoId, overlayId) {
            const video = document.getElementById(videoId);
            const overlay = document.getElementById(overlayId);
            if (video && overlay) {
                overlay.addEventListener("click", function(e) {
                    e.stopPropagation(); 
                    video.muted = false;
                    video.loop = true; 
                    video.currentTime = 0;
                    video.play().catch(err => {
                        console.warn("Autoplay bloqueado pelo navegador", err);
                    });
                    overlay.style.opacity = "0";
                    setTimeout(() => { overlay.style.display = "none"; }, 500); 

                    if (window.clarity) {
                        window.clarity("event", "Video_Assistido_" + videoId);
                    }
                });
                video.addEventListener("click", function() {
                    if (overlay.style.display === "none") {
                        if (video.paused) { video.play(); } else { video.pause(); }
                    }
                });
            }
        }

        setupVideo("vision-video", "unmute-overlay");
        setupVideo("mibo-video", "mibo-unmute-overlay");
    });
</script>
