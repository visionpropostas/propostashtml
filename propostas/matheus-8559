                    <div class="w-full">
                        <div class="bg-white border border-gray-100 rounded-xl p-3 flex items-center justify-between shadow-sm text-left relative overflow-hidden">
                            <div class="absolute top-0 left-0 w-1 h-full bg-gray-300"></div>
                            <div class="pl-1">
                                <span class="block text-[8px] uppercase font-bold text-gray-500 mb-0.5">Total Financiado</span>
