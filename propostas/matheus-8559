            el2.innerHTML = `
                <div class="bg-[#faf8f0] border border-[#e8dcc4] rounded-[1.25rem] p-4 md:p-6 w-full flex flex-col items-center relative shadow-sm">
                    <p class="text-[8px] md:text-[10px] text-brand-goldDark uppercase tracking-widest font-bold mb-1">Cartão de Crédito</p>
                    <div class="flex items-baseline justify-center gap-1 mb-4 mt-1">
                        <span class="text-xs md:text-lg font-bold text-gray-500">${inst}x</span> 
                        <span class="text-base md:text-3xl font-black text-gray-900 tracking-tight">R$ ${formatCurrency(val2)}</span>
                    </div>
                    
                    <div class="w-full">
                        <div class="bg-white border border-gray-200 rounded-xl p-3 flex items-center justify-between shadow-sm text-left relative overflow-hidden">
                            <div class="absolute top-0 left-0 w-1 h-full bg-gray-300"></div>
                            <div class="pl-1">
                                <span class="block text-[8px] uppercase font-bold text-gray-500 mb-0.5">Total Financiado</span>
                                <span class="text-[10px] md:text-sm font-extrabold text-gray-900">R$ ${formatCurrency(t2)}</span>
