        }
        lucide.createIcons();
    }

    // REVEAL ON SCROLL
    const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) entry.target.classList.add('active');
        });
    }, { threshold: 0.1 });
    document.querySelectorAll('.reveal').forEach(el => observer.observe(el));

    // ANIMATE COUNTERS
    function animateCounter(el, target) {
        let current = 0;
        const increment = Math.ceil(target / 40) || 1;
        const interval = setInterval(() => {
            current = Math.min(current + increment, target);
            el.textContent = current;
            if (current === target) clearInterval(interval);
        }, 40);
    }
    const counterObserver = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                const el = entry.target;
                const target = parseInt(el.getAttribute('data-target'));
                animateCounter(el, target);
                counterObserver.unobserve(el);
            }
        });
    }, { threshold: 0.5 });
    document.querySelectorAll('[data-target]').forEach(el => counterObserver.observe(el));

    // ACCORDION
    function toggleAccordion(btn) {
        const item = btn.parentElement;
        const isOpen = item.classList.contains('open');
        document.querySelectorAll('.accordion-item').forEach(i => i.classList.remove('open'));
        if (!isOpen) item.classList.add('open');
        lucide.createIcons();
    }

    // NAVBAR E CTA SCROLL
    window.addEventListener('scroll', () => {
        const navbar = document.getElementById('navbar');
        const ctaFloat = document.getElementById('cta-float');
        
        if (window.scrollY > 50) {
            if(navbar) navbar.classList.add('shadow-md');
        } else {
            if(navbar) navbar.classList.remove('shadow-md');
        }

        if (window.scrollY > 400) {
            if(ctaFloat) {
                ctaFloat.classList.remove('hidden', 'opacity-0', 'translate-y-10', 'pointer-events-none');
                ctaFloat.classList.add('opacity-100', 'translate-y-0');
            }
        } else {
            if(ctaFloat) {
                ctaFloat.classList.remove('opacity-100', 'translate-y-0');
                ctaFloat.classList.add('opacity-0', 'translate-y-10', 'pointer-events-none');
            }
        }
    });

    // VIDEO UNMUTE
    document.addEventListener("DOMContentLoaded", function() {
        const video = document.getElementById("vision-video");
        const overlay = document.getElementById("unmute-overlay");
        if (video && overlay) {
            overlay.addEventListener("click", function(e) {
                e.stopPropagation(); 
                video.muted = false;
                video.loop = false; 
                video.currentTime = 0;
                video.play();
                overlay.style.opacity = "0";
                setTimeout(() => { overlay.style.display = "none"; }, 500); 

                // Rastreamento Clarity - Vídeo Assistido
                if (window.clarity) {
                    window.clarity("event", "Video_Assistido_Vision_Video");
                }
            });
            video.addEventListener("click", function() {
                if (overlay.style.display === "none") {
                    if (video.paused) { video.play(); } else { video.pause(); }
                }
            });
        }

        const cameraVideo = document.getElementById("camera-video");
        const cameraOverlay = document.getElementById("unmute-overlay-camera");
        if (cameraVideo && cameraOverlay) {
            cameraOverlay.addEventListener("click", function(e) {
                e.stopPropagation(); 
                cameraVideo.muted = false;
                cameraVideo.loop = false; 
                cameraVideo.currentTime = 0;
                cameraVideo.play();
                cameraOverlay.style.opacity = "0";
                setTimeout(() => { cameraOverlay.style.display = "none"; }, 500); 

                // Rastreamento Clarity - Vídeo Assistido
                if (window.clarity) {
                    window.clarity("event", "Video_Assistido_Camera_Video");
                }
            });
            cameraVideo.addEventListener("click", function() {
                if (cameraOverlay.style.display === "none") {
                    if (cameraVideo.paused) { cameraVideo.play(); } else { cameraVideo.pause(); }
                }
            });
        }
    });
</script>
</body>
