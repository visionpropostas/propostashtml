            el2.innerHTML = `
                <div class="bg-[#faf8f0] border border-[#e8dcc4] rounded-[1.25rem] p-4 md:p-6 w-full flex flex-col items-center relative shadow-sm">
                    <p class="text-[8px] md:text-[10px] text-brand-goldDark uppercase tracking-widest font-bold mb-1">À Vista (PIX)</p>
                    <span class="text-sm md:text-3xl font-black text-gray-900 tracking-tight mb-4">R$ ${formatCurrency(p2)}</span>
                    
                    <div class="w-full space-y-2">
                        <div class="bg-white border border-gray-100 rounded-lg py-2 flex flex-col items-center justify-center relative overflow-hidden shadow-sm">
                            <div class="absolute top-0 left-0 w-1 h-full bg-[#34d399]"></div>
                            <span class="text-[8px] font-bold uppercase tracking-widest text-brand-goldDark mb-0.5">Sinal 50%</span>
                            <span class="text-xs font-bold text-gray-900">R$ ${formatCurrency(h2)}</span>
                        </div>
                        <div class="bg-white border border-gray-100 rounded-lg py-2 flex flex-col items-center justify-center relative overflow-hidden shadow-sm">
                            <div class="absolute top-0 left-0 w-1.5 h-full bg-[#c8a048]"></div>
                            <span class="text-[8px] font-bold uppercase tracking-widest text-brand-goldDark mb-0.5">Na Entrega</span>
                            <span class="text-xs font-bold text-gray-900">R$ ${formatCurrency(h2)}</span>
                        </div>
                    </div>
                </div>
            `;
        } else {
            const inst = parseInt(select.value);
            const rateMultiplier = cardRates[inst];
            
            const t1 = p1 * rateMultiplier;
            const t2 = p2 * rateMultiplier;

            const val1 = t1 / inst;
            const val2 = t2 / inst;

            el1.innerHTML = `
                <div class="bg-[#faf8f0] border border-[#e8dcc4] rounded-[1.25rem] p-4 md:p-6 w-full flex flex-col items-center relative shadow-sm">
                    <p class="text-[8px] md:text-[10px] text-brand-goldDark uppercase tracking-widest font-bold mb-1">Cartão de Crédito</p>
                    <div class="flex items-baseline justify-center gap-1 mb-4 mt-1">
                        <span class="text-xs md:text-lg font-bold text-gray-500">${inst}x</span> 
                        <span class="text-base md:text-3xl font-black text-gray-900 tracking-tight">R$ ${formatCurrency(val1)}</span>
