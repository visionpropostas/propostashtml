    // Toggle Combo Payment
    function setComboPayment(mode) {
        const btnAvista = document.getElementById('btn-combo-avista');
        const btnParcelado = document.getElementById('btn-combo-parcelado');
        const priceDisplay = document.getElementById('price-combo-display');
