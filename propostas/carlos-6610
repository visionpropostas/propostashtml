                        <span class="text-4xl md:text-5xl font-black text-gray-900">${formatCurrency(installmentValue)}</span>
                    </div>
                    <div class="inline-flex items-center gap-1.5 bg-blue-50 border border-blue-200 text-blue-700 px-3 py-1 rounded-full w-fit shadow-sm mt-2 mb-3 font-tech">
                        <i data-lucide="credit-card" class="w-4 h-4"></i>
                        <span class="text-[10px] md:text-[11px] font-bold uppercase tracking-widest">Cartão de Crédito Coletivo</span>
                    </div>
                    <p class="text-[10px] text-gray-500 font-medium font-sans">Total do Projeto Parcelado: R$ ${formatCurrency(totalWithRate)}</p>
                </div>
            `;
        }
        
        updateWhatsAppLink();
        initIcons();
    }

    // SUBSCREVE O EVENTO DE CARREGAMENTO INICIAL DA PÁGINA
    window.addEventListener("load", () => {
        renderEquipmentList();
        setPaymentMode('avista');
    });

    // SISTEMA DE REVELAÇÃO SUAVE NO SCROLL DO NAVEGADOR
    const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) entry.target.classList.add('active');
        });
    }, { threshold: 0.05 });
    document.querySelectorAll('.reveal').forEach(el => observer.observe(el));

    // MONITORA O SCROLL PARA AJUSTAR A OPACIDADE DA NAVBAR E CTA FLUTUANTE
    window.addEventListener('scroll', () => {
        const navbar = document.getElementById('navbar');
        const ctaFloat = document.getElementById('cta-float');
        
        if (window.scrollY > 50) {
            if(navbar) navbar.classList.add('shadow-md');
        } else {
            if(navbar) navbar.classList.remove('shadow-md');
        }

        if (window.scrollY > 400) {
            if(ctaFloat) {
                ctaFloat.classList.remove('hidden', 'opacity-0', 'translate-y-10', 'pointer-events-none');
                ctaFloat.classList.add('opacity-100', 'translate-y-0');
            }
        } else {
            if(ctaFloat) {
                ctaFloat.classList.add('opacity-0', 'translate-y-10', 'pointer-events-none');
            }
        }
    });

    // PARAMETRIZAÇÃO DE REPRODUÇÃO AUDIOVISUAL COM CLIQUE PARA DESMUDAR
    document.addEventListener("DOMContentLoaded", function() {
        const video = document.getElementById("vision-video");
        const overlay = document.getElementById("unmute-overlay");
        if (video && overlay) {
            overlay.addEventListener("click", function(e) {
                e.stopPropagation(); 
                video.muted = false;
                video.loop = true; 
                video.currentTime = 0;
                video.play().catch(err => {
                    console.warn("Autoplay bloqueado pelo navegador do utilizador", err);
                });
                overlay.style.opacity = "0";
                setTimeout(() => { overlay.style.display = "none"; }, 500); 

                if (window.clarity) {
                    window.clarity("event", "Video_Assistido_VisionVideo");
                }
            });
            video.addEventListener("click", function() {
                if (overlay.style.display === "none") {
                    if (video.paused) { video.play(); } else { video.pause(); }
                }
            });
        }
    });
</script>
</body>
</html>
