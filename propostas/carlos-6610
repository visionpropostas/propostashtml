        const select = document.getElementById('installment-select');

        if (!el1) return;

        const basePriceVal = prices.basePrice;

        if (currentMode === 'avista') {
            // Sinais de pagamento coletivo (sinal de 50% de R$ 9.790,00) sem terminar em dígito zero
            const h1 = 4895; 
            const h2 = 4895;

            el1.innerHTML = `
                <div class="flex flex-col items-center w-full animate-fade-in font-sans">
                    <p class="text-[8px] md:text-[10px] text-[#8a6208] uppercase tracking-widest font-bold mb-1">À Vista no PIX (Sem Juros)</p>
                    <span class="text-4xl md:text-5xl font-black text-gray-900 tracking-tight mb-4">R$ ${formatCurrency(basePriceVal)}</span>
                    
                    <div class="w-full space-y-2">
                        <div class="bg-white border border-gray-200 rounded-xl py-2.5 flex flex-col items-center justify-center relative overflow-hidden shadow-sm">
                            <div class="absolute top-0 left-0 w-1 h-full bg-[#34d399] rounded-l-lg"></div>
                            <span class="text-[8px] font-bold uppercase tracking-widest text-brand-goldDark mb-0.5">Sinal para Lançamento do Projeto (50%)</span>
                            <span class="text-sm font-bold text-gray-900">R$ ${formatCurrency(h1)}</span>
                        </div>
                        <div class="bg-white border border-gray-200 rounded-xl py-2.5 flex flex-col items-center justify-center relative overflow-hidden shadow-sm">
                            <div class="absolute top-0 left-0 w-1.5 h-full bg-[#c8a048] rounded-l-lg"></div>
                            <span class="text-[8px] font-bold uppercase tracking-widest text-brand-goldDark mb-0.5">Saldo na Conclusão e Entrega da Instalação (50%)</span>
                            <span class="text-sm font-bold text-gray-900">R$ ${formatCurrency(h2)}</span>
                        </div>
                    </div>
                </div>
            `;
        } else {
            const inst = parseInt(select.value);
            const totalWithRate = prices.rates[inst] || basePriceVal;
            const installmentValue = totalWithRate / inst;

            el1.innerHTML = `
                <div class="flex flex-col items-center w-full mt-2 mb-2 animate-fade-in font-sans">
                    <div class="flex items-baseline justify-center gap-1.5 mb-2">
                        <span class="text-xl md:text-2xl font-bold text-brand-yellow">${inst}x de R$</span> 
                        <span class="text-4xl md:text-5xl font-black text-gray-900">${formatCurrency(installmentValue)}</span>
                    </div>
                    <div class="inline-flex items-center gap-1.5 bg-blue-50 border border-blue-200 text-blue-700 px-3 py-1 rounded-full w-fit shadow-sm mt-2 mb-3 font-tech">
                        <i data-lucide="credit-card" class="w-4 h-4"></i>
                        <span class="text-[10px] md:text-[11px] font-bold uppercase tracking-widest">Cartão de Crédito Coletivo</span>
                    </div>
                    <p class="text-[10px] text-gray-500 font-medium font-sans">Total do Projeto Parcelado: R$ ${formatCurrency(totalWithRate)}</p>
                </div>
            `;
        }
        
        updateWhatsAppLink();
        initIcons();
    }

    // SUBSCREVE O EVENTO DE CARREGAMENTO INICIAL DA PÁGINA
    window.addEventListener("load", () => {
        renderEquipmentList();
        setPaymentMode('avista');
    });

    // SISTEMA DE REVELAÇÃO SUAVE NO SCROLL DO NAVEGADOR
    const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) entry.target.classList.add('active');
        });
    }, { threshold: 0.05 });
    document.querySelectorAll('.reveal').forEach(el => observer.observe(el));

    // MONITORA O SCROLL PARA AJUSTAR A OPACIDADE DA NAVBAR E CTA FLUTUANTE
    window.addEventListener('scroll', () => {
        const navbar = document.getElementById('navbar');
        const ctaFloat = document.getElementById('cta-float');
        
        if (window.scrollY > 50) {
            if(navbar) navbar.classList.add('shadow-md');
        } else {
            if(navbar) navbar.classList.remove('shadow-md');
        }

        if (window.scrollY > 400) {
            if(ctaFloat) {
                ctaFloat.classList.remove('hidden', 'opacity-0', 'translate-y-10', 'pointer-events-none');
                ctaFloat.classList.add('opacity-100', 'translate-y-0');
            }
        } else {
            if(ctaFloat) {
                ctaFloat.classList.add('opacity-0', 'translate-y-10', 'pointer-events-none');
            }
        }
    });

    // PARAMETRIZAÇÃO DE REPRODUÇÃO AUDIOVISUAL COM CLIQUE PARA DESMUDAR
    document.addEventListener("DOMContentLoaded", function() {
        const video = document.getElementById("vision-video");
        const overlay = document.getElementById("unmute-overlay");
        if (video && overlay) {
            overlay.addEventListener("click", function(e) {
                e.stopPropagation(); 
                video.muted = false;
                video.loop = true; 
                video.currentTime = 0;
                video.play().catch(err => {
                    console.warn("Autoplay bloqueado pelo navegador do utilizador", err);
                });
                overlay.style.opacity = "0";
                setTimeout(() => { overlay.style.display = "none"; }, 500); 

                if (window.clarity) {
                    window.clarity("event", "Video_Assistido_VisionVideo");
                }
            });
            video.addEventListener("click", function() {
                if (overlay.style.display === "none") {
                    if (video.paused) { video.play(); } else { video.pause(); }
                }
            });
        }
    });
</script>
