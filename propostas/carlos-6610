            message = `Olá Glícia, analisei a proposta de modernização de controle de acesso do prédio do Carlos e gostaríamos de aprovar o projeto com pagamento à Vista de R$ ${formatCurrency(basePriceVal)} via PIX.`;
        } else {
            const select = document.getElementById('installment-select');
            const installments = select ? select.value : '12';
            const totalWithRate = prices.rates[installments] || basePriceVal;
            const installmentValue = totalWithRate / parseInt(installments);
            message = `Olá Glícia, analisei a proposta de modernização de controle de acesso do prédio do Carlos e gostaríamos de aprovar o projeto parcelado em ${installments}x de R$ ${formatCurrency(installmentValue)} no cartão de crédito.`;
        }

        btnLink.href = "https://wa.me/5511930816696?text=" + encodeURIComponent(message);
    }

    // CALCULA OS VALORES DO ORÇAMENTO E INJETA NO CONTEÚDO DA PÁGINA
    function updatePrices() {
