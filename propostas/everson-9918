                    <p class="text-[10px] md:text-sm text-gray-800 leading-snug md:leading-relaxed font-semibold">${item}</p>
                </div>
            `;
        });

        initIcons();
    }

    function setPaymentMode(mode) {
        currentMode = mode;
        const bg = document.getElementById('toggle-bg');
        const btnPix = document.getElementById('btn-avista');
        const btnParcelado = document.getElementById('btn-parcelado');
        const selectContainer = document.getElementById('installment-container');

        if (mode === 'avista') {
            if (bg) bg.style.transform = 'translateX(0)';
            if (btnPix) {
                btnPix.classList.remove('text-gray-500');
                btnPix.classList.add('text-gray-900');
            }
            if (btnParcelado) {
                btnParcelado.classList.remove('text-gray-900');
                btnParcelado.classList.add('text-gray-500');
            }
            
            if (selectContainer) {
                selectContainer.classList.add('opacity-0', 'pointer-events-none');
                setTimeout(() => { if(selectContainer) selectContainer.classList.add('hidden'); }, 300);
            }
        } else {
            if (bg) bg.style.transform = 'translateX(100%)';
            if (btnParcelado) {
                btnParcelado.classList.remove('text-gray-500');
                btnParcelado.classList.add('text-black');
            }
            if (btnPix) {
                btnPix.classList.remove('text-black');
                btnPix.classList.add('text-gray-500');
            }
            
            if (selectContainer) {
                selectContainer.classList.remove('hidden');
                setTimeout(() => { if(selectContainer) selectContainer.classList.remove('opacity-0', 'pointer-events-none'); }, 10);
            }
        }
        updatePrices();
    }

    function formatCurrency(value) {
        return value.toLocaleString('pt-BR', {minimumFractionDigits: 0, maximumFractionDigits: 0});
    }

    function updatePrices() {
        const el1 = document.getElementById('price-opt1');
        const select = document.getElementById('installment-select');
        
        const data = configData;

        if (!el1) return;

        if (currentMode === 'avista') {
            // Sinais PIX sem terminar com o dígito zero
            const h1 = 5217;
            const h2 = 5218;

            el1.innerHTML = `
                <div class="flex flex-col items-center w-full animate-fade-in">
                    <p class="text-[8px] md:text-[10px] text-[#8a6208] uppercase tracking-widest font-bold mb-1">À Vista no PIX (Sem Juros)</p>
                    <span class="text-4xl md:text-5xl font-black text-gray-900 tracking-tight mb-4">R$ ${formatCurrency(data.basePrice)}</span>
                    
                    <div class="w-full space-y-2">
                        <div class="bg-white border border-gray-200 rounded-xl py-2.5 flex flex-col items-center justify-center relative overflow-hidden shadow-sm">
                            <div class="absolute top-0 left-0 w-1 h-full bg-[#34d399] rounded-l-lg"></div>
                            <span class="text-[8px] font-bold uppercase tracking-widest text-brand-goldDark mb-0.5">Sinal para Lançamento e Infraestrutura (50%)</span>
                            <span class="text-sm font-bold text-gray-900">R$ ${formatCurrency(h1)}</span>
                        </div>
                        <div class="bg-white border border-gray-200 rounded-xl py-2.5 flex flex-col items-center justify-center relative overflow-hidden shadow-sm">
                            <div class="absolute top-0 left-0 w-1.5 h-full bg-[#c8a048] rounded-l-lg"></div>
                            <span class="text-[8px] font-bold uppercase tracking-widest text-brand-goldDark mb-0.5">Saldo na Conclusão e Ativação do Sistema (50%)</span>
                            <span class="text-sm font-bold text-gray-900">R$ ${formatCurrency(h2)}</span>
                        </div>
                    </div>
                </div>
            `;
        } else {
            const inst = parseInt(select.value);
            const totalWithRate = data.rates[inst] || data.basePrice;
            const installmentValue = Math.floor(totalWithRate / inst);

            el1.innerHTML = `
                <div class="flex flex-col items-center w-full mt-2 mb-2 animate-fade-in">
                    <div class="flex items-baseline justify-center gap-1.5 mb-2">
                        <span class="text-xl md:text-2xl font-bold text-brand-yellow">${inst}x de R$</span> 
                        <span class="text-4xl md:text-5xl font-black text-gray-900">${formatCurrency(installmentValue)}</span>
                    </div>
                    <div class="inline-flex items-center gap-1.5 bg-blue-50 border border-blue-200 text-blue-700 px-3 py-1 rounded-full w-fit shadow-sm mt-2 mb-3">
                        <i data-lucide="credit-card" class="w-4 h-4"></i>
                        <span class="text-[10px] md:text-[11px] font-bold uppercase tracking-widest">Cartão de Crédito</span>
                    </div>
                    <p class="text-[10px] text-gray-500 font-medium">Total do Projeto Parcelado: R$ ${formatCurrency(totalWithRate)}</p>
                </div>
            `;
        }
        
        updateWhatsAppLink();
        initIcons();
    }

    window.addEventListener("load", () => {
        renderEquipmentList();
        setPaymentMode('avista');
    });

    const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) entry.target.classList.add('active');
        });
    }, { threshold: 0.05 });
    document.querySelectorAll('.reveal').forEach(el => observer.observe(el));

    window.addEventListener('scroll', () => {
        const navbar = document.getElementById('navbar');
        const ctaFloat = document.getElementById('cta-float');
        
        if (window.scrollY > 50) {
            if(navbar) navbar.classList.add('shadow-md');
        } else {
            if(navbar) navbar.classList.remove('shadow-md');
        }

        if (window.scrollY > 400) {
            if(ctaFloat) {
                ctaFloat.classList.remove('hidden', 'opacity-0', 'translate-y-10', 'pointer-events-none');
                ctaFloat.classList.add('opacity-100', 'translate-y-0');
            }
        } else {
            if(ctaFloat) {
                ctaFloat.classList.add('opacity-0', 'translate-y-10', 'pointer-events-none');
            }
        }
    });

    document.addEventListener("DOMContentLoaded", function() {
        function setupVideo(videoId, overlayId) {
            const video = document.getElementById(videoId);
            const overlay = document.getElementById(overlayId);
            if (video && overlay) {
                overlay.addEventListener("click", function(e) {
                    e.stopPropagation(); 
                    video.muted = false;
                    video.loop = true; 
                    video.currentTime = 0;
                    video.play().catch(err => {
                        console.warn("Autoplay bloqueado pelo navegador", err);
                    });
                    overlay.style.opacity = "0";
                    setTimeout(() => { overlay.style.display = "none"; }, 500); 

                    if (window.clarity) {
                        window.clarity("event", "Video_Assistido_" + videoId);
                    }
                });
                video.addEventListener("click", function() {
                    if (overlay.style.display === "none") {
                        if (video.paused) { video.play(); } else { video.pause(); }
                    }
                });
            }
        }

        setupVideo("vision-video", "unmute-overlay");
        setupVideo("demo-shorts-video", "unmute-overlay-shorts");
    });
</script>
</body>
</html>
