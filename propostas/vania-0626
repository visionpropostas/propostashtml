        const overlayHero = document.getElementById("unmute-overlay");
        
        if (videoHero && overlayHero) {
            overlayHero.addEventListener("click", function(e) {
                e.stopPropagation(); 
                videoHero.muted = false;
                videoHero.loop = false; 
                videoHero.currentTime = 0;
                videoHero.play();
                overlayHero.style.opacity = "0";
                setTimeout(() => { overlayHero.style.display = "none"; }, 500); 
            });

            videoHero.addEventListener("click", function() {
                if (overlayHero.style.display === "none") {
                    if (videoHero.paused) { videoHero.play(); } else { videoHero.pause(); }
                }
            });
        }

        // 2. Vídeo Câmera 360 (Secção Solução)
        const videoCam = document.getElementById("camera-video");
        const overlayCam = document.getElementById("unmute-overlay-camera");
        
        if (videoCam && overlayCam) {
            overlayCam.addEventListener("click", function(e) {
                e.stopPropagation(); 
                videoCam.muted = false;
                videoCam.loop = false; 
                videoCam.currentTime = 0;
                videoCam.play();
                overlayCam.style.opacity = "0";
                setTimeout(() => { overlayCam.style.display = "none"; }, 500); 
            });

            videoCam.addEventListener("click", function() {
                if (overlayCam.style.display === "none") {
                    if (videoCam.paused) { videoCam.play(); } else { videoCam.pause(); }
                }
            });
        }
    });
</script>
