                btn.classList.add('active', 'border-brand-yellow', 'bg-black', 'text-brand-yellow', 'shadow-md');
                btn.classList.remove('border-gray-200', 'text-gray-600');
            } else {
                btn.classList.remove('active', 'border-brand-yellow', 'bg-black', 'text-brand-yellow', 'shadow-md');
                btn.classList.add('border-gray-200', 'text-gray-600');
            }
        });

        // 2. Atualiza Estilo dos Botões de SD Card
        ['128', '256'].forEach(size => {
            const btn = document.getElementById(`btn-sd-${size}`);
            if(size === currentSd) {
                btn.classList.add('active', 'border-brand-yellow', 'bg-black', 'text-brand-yellow', 'shadow-md');
                btn.classList.remove('border-gray-200', 'text-gray-600');
            } else {
                btn.classList.remove('active', 'border-brand-yellow', 'bg-black', 'text-brand-yellow', 'shadow-md');
                btn.classList.add('border-gray-200', 'text-gray-600');
            }
        });

        // 3. Atualiza Toggle da Fechadura
