        <div class="grid md:grid-cols-3 gap-8 reveal active">
            <!-- Card 1 -->
            <div class="bg-white rounded-[2rem] p-8 shadow-premium border border-gray-100 relative overflow-hidden group hover:-translate-y-1 transition-transform duration-300 flex flex-col text-left">
