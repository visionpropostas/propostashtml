    // REVEAL ON SCROLL
    const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                entry.target.classList.add('active');
            }
        });
    }, { threshold: 0.1 });
    document.querySelectorAll('.reveal').forEach(el => observer.observe(el));

    // COUNTERS
    function animateCounter(el, target) {
        let current = 0;
        const increment = Math.ceil(target / 40) > 0 ? Math.ceil(target / 40) : 1; 
        const interval = setInterval(() => {
            current = Math.min(current + increment, target);
            el.textContent = current + (el.textContent.includes('%') ? '%' : ''); 
            if (target === 100) el.textContent = current + '%';
            if (current === target) clearInterval(interval);
        }, 30);
    }
    
    const counterObserver = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                const el = entry.target;
                const target = parseInt(el.getAttribute('data-target'));
                if (!isNaN(target)) {
                     el.textContent = '0';
                     animateCounter(el, target);
                }
                counterObserver.unobserve(el);
            }
        });
    }, { threshold: 0.5 });
    document.querySelectorAll('[data-target]').forEach(el => counterObserver.observe(el));

    window.addEventListener('scroll', () => {
        const navbar = document.getElementById('navbar');
        const ctaFloat = document.getElementById('cta-float');
        if (!navbar || !ctaFloat) return;
        
        if (window.scrollY > 50) {
            navbar.classList.add('shadow-md', 'py-1');
        } else {
            navbar.classList.remove('shadow-md', 'py-1');
        }

        if (window.scrollY > 400) {
            ctaFloat.classList.remove('opacity-0', 'translate-y-10', 'pointer-events-none');
            ctaFloat.classList.add('opacity-100', 'translate-y-0');
        } else {
            ctaFloat.classList.add('opacity-0', 'translate-y-10', 'pointer-events-none');
            ctaFloat.classList.remove('opacity-100', 'translate-y-0');
        }
    });

    // ACCORDION
    function toggleAccordion(btn) {
        const item = btn.parentElement;
        if (!item) return;
        const isOpen = item.classList.contains('open');
        document.querySelectorAll('.accordion-item').forEach(i => i.classList.remove('open'));
        if (!isOpen) {
            item.classList.add('open');
        }
    }

    // VIDEO UNMUTE & PLAY-PAUSE (HERO AND HD VIDEOS)
    document.addEventListener("DOMContentLoaded", function() {
        const heroVideo = document.getElementById("vision-video");
        const heroOverlay = document.getElementById("unmute-overlay");
        
        if (heroVideo && heroOverlay) {
            heroOverlay.addEventListener("click", function(e) {
                e.stopPropagation(); 
                heroVideo.muted = false;
                heroVideo.loop = false; 
                heroVideo.currentTime = 0;
                heroVideo.play().catch(err => { console.log("Mídia bloqueada pelo navegador:", err); });
                heroOverlay.style.opacity = "0";
                setTimeout(() => { heroOverlay.style.display = "none"; }, 500); 
            });

            heroVideo.addEventListener("click", function() {
                if (heroOverlay.style.display === "none") {
                    if (heroVideo.paused) { 
                        heroVideo.play(); 
                    } else { 
                        heroVideo.pause(); 
                    }
                }
            });
        }

        const hdVideo = document.getElementById("hd-video");
        const hdOverlay = document.getElementById("unmute-overlay-hd");

        if (hdVideo && hdOverlay) {
            hdOverlay.addEventListener("click", function(e) {
                e.stopPropagation();
                hdVideo.muted = false;
                hdVideo.loop = false;
                hdVideo.currentTime = 0;
                hdVideo.play().catch(err => { console.log("Mídia bloqueada pelo navegador:", err); });
                hdOverlay.style.opacity = "0";
                setTimeout(() => { hdOverlay.style.display = "none"; }, 500);
            });

            hdVideo.addEventListener("click", function() {
                if (hdOverlay.style.display === "none") {
                    if (hdVideo.paused) {
                        hdVideo.play();
                    } else {
                        hdVideo.pause();
                    }
                }
            });
        }
    });
