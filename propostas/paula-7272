        3: Math.round(creditBase / 3),
        4: Math.round(creditBase / 4),
        5: Math.round(creditBase / 5),
        6: Math.round(creditBase / 6),
        7: Math.round(creditBase / 7),
        8: Math.round(creditBase / 8),
        9: Math.round(creditBase / 9),
        10: Math.round(creditBase / 10),
        11: Math.round(creditBase / 11),
        12: Math.round(creditBase / 12)
