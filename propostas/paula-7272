        } else {
            errorMsg.classList.remove('hidden');
            inputElement.style.borderColor = 'rgba(239,68,68,0.5)';
            setTimeout(() => {
                errorMsg.classList.add('hidden');
                inputElement.style.borderColor = '';
            }, 3000);
        }
    }

    const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                entry.target.classList.add('active');
            }
        });
    }, { threshold: 0.1 });
    document.querySelectorAll('.reveal').forEach(el => observer.observe(el));

    function animateCounter(el, target) {
        let current = 0;
        const increment = Math.ceil(target / 40) > 0 ? Math.ceil(target / 40) : 1; 
        const interval = setInterval(() => {
            current = Math.min(current + increment, target);
            el.textContent = current; 
            if (current === target) clearInterval(interval);
        }, 40);
    }
    
    const counterObserver = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                const el = entry.target;
                const target = parseInt(el.getAttribute('data-target'));
                if (!isNaN(target)) {
                     el.textContent = '0';
                     animateCounter(el, target);
                }
                counterObserver.unobserve(el);
            }
        });
    }, { threshold: 0.5 });
    document.querySelectorAll('[data-target]').forEach(el => counterObserver.observe(el));

    window.addEventListener('scroll', () => {
        const navbar = document.getElementById('navbar');
        const ctaFloat = document.getElementById('cta-float');
        if (!navbar || !ctaFloat) return;
        
        if (window.scrollY > 50) {
            navbar.classList.add('shadow-md', 'py-1');
        } else {
            navbar.classList.remove('shadow-md', 'py-1');
        }

        if (window.scrollY > 400) {
            ctaFloat.classList.remove('opacity-0', 'translate-y-10', 'pointer-events-none');
            ctaFloat.classList.add('opacity-100', 'translate-y-0');
        } else {
            ctaFloat.classList.add('opacity-0', 'translate-y-10', 'pointer-events-none');
            ctaFloat.classList.remove('opacity-100', 'translate-y-0');
        }
    });

    function toggleAccordion(btn) {
        const item = btn.parentElement;
        if (!item) return;
        const isOpen = item.classList.contains('open');
        document.querySelectorAll('.accordion-item').forEach(i => i.classList.remove('open'));
        if (!isOpen) {
            item.classList.add('open');
        }
    }

    document.addEventListener("DOMContentLoaded", function() {
        const heroVideo = document.getElementById("vision-video");
        const heroOverlay = document.getElementById("unmute-overlay");
        
        if (heroVideo && heroOverlay) {
            heroOverlay.addEventListener("click", function(e) {
                e.stopPropagation(); 
                heroVideo.muted = false;
                heroVideo.loop = false; 
                heroVideo.currentTime = 0;
                heroVideo.play().catch(err => { console.log("Mídia bloqueada pelo navegador:", err); });
                heroOverlay.style.opacity = "0";
                setTimeout(() => { heroOverlay.style.display = "none"; }, 500); 
            });

            heroVideo.addEventListener("click", function() {
                if (heroOverlay.style.display === "none") {
                    if (heroVideo.paused) { 
                        heroVideo.play(); 
                    } else { 
                        heroVideo.pause(); 
                    }
                }
            });
        }

        const facialDemoVideo = document.getElementById("facial-demo-video");
        const facialDemoOverlay = document.getElementById("facial-unmute-overlay");
        if (facialDemoVideo && facialDemoOverlay) {
            facialDemoOverlay.addEventListener("click", function(e) {
                e.stopPropagation();
                facialDemoVideo.muted = false;
                facialDemoVideo.loop = false;
                facialDemoVideo.currentTime = 0;
                facialDemoVideo.play().catch(err => { console.log("Mídia bloqueada:", err); });
                facialDemoOverlay.style.opacity = "0";
                setTimeout(() => { facialDemoOverlay.style.display = "none"; }, 500);
            });

            facialDemoVideo.addEventListener("click", function() {
                if (facialDemoOverlay.style.display === "none") {
                    if (facialDemoVideo.paused) {
                        facialDemoVideo.play();
                    } else {
                        facialDemoVideo.pause();
                    }
                }
            });
        }
    });
</script>
