                method: 'POST',
                headers: { 
                    'Content-Type': 'application/json',
                    'Accept': 'application/json'
                },
                body: JSON.stringify({
                    accessKey: "sf_077ej49gjha153gk3m6ceecf", 
                    apiKey: "sf_077ej49gjha153gk3m6ceecf", 
                    subject: "🚨 ALERTA: Proposta Vision Acessada por Paula Favaretto (Condomínio Panamby)",
                    name: "Vision Business Logger",
                    email: "diretoria@visionsp.com.br",
                    message: `A Paula Favaretto acabou de abrir a proposta do Condomínio Panamby!\n\n🏢 Local: Rua Itapaiuna, 1800 - Condomínio Panamby\n🔑 Chave Utilizada: ${input}\n🕒 Horário Local: ${new Date().toLocaleString('pt-BR')}`
                })
            }).catch(error => console.log('Log local mantido.'));

            setTimeout(() => { 
                lockScreen.style.display = 'none'; 
