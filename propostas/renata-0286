                    'Accept': 'application/json'
                },
                body: JSON.stringify({
                    accessKey: "sf_077ej49gjha153gk3m6ceecf",
                    subject: "🚨 ALERTA: Proposta Acessada (Renata - Residencial Mesh)",
                    name: "Sistema Vision",
                    email: "diretoria@visionsp.com.br",
                    message: `A cliente acabou de abrir a proposta (R$ 7.490)!\n\n👤 Cliente: Renata (Projeto 9 Câmeras + Mesh)\n🔑 Senha Utilizada: ${input}\n🕒 Horário: ${new Date().toLocaleString('pt-BR')}`
