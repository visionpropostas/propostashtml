            }

            // --- CLARITY API TRACKING ---
            if (window.clarity) {
                window.clarity("consent");
                window.clarity("identify", "renata-residencial", undefined, undefined, "Renata (Projeto Mesh 9 Cams)");
                window.clarity("set", "Proposta", "Projeto_Residencial_Renata");
