        const btnUnlock = document.getElementById('btn-unlock');
        const unlockIcon = document.getElementById('unlock-icon');
        const unlockText = document.getElementById('unlock-text');
        const unlockArrow = document.getElementById('unlock-arrow');
        
        if (formattedInput === 'BRUNA2026' || formattedInput === 'BRUNA' || formattedInput === 'VISION') {
            
            btnUnlock.disabled = true;
            if (unlockText) unlockText.textContent = "Validando Acesso...";
            if (unlockIcon) unlockIcon.className = "w-5 h-5 animate-spin text-black";
            if (unlockArrow) unlockArrow.style.display = 'none';

            setTimeout(() => {
                const lockScreen = document.getElementById('lock-screen');
                lockScreen.style.opacity = '0';

                // Autoplay mutado do vídeo
                const video = document.getElementById("vision-video");
                if (video && video.paused) {
                    video.muted = true;
                    video.play().catch(e => {});
                }

                if (window.clarity) {
                    window.clarity("consent");
                    window.clarity("identify", "bruna-poe", undefined, undefined, "Bruna Horn (POE Premium)");
                    window.clarity("set", "Proposta", "Projeto_POE_Bruna_Horn");
                    window.clarity("event", "Proposta_Desbloqueada");
                }

                fetch('https://api.staticforms.dev/submit', {
                    method: 'POST',
                    headers: { 
                        'Content-Type': 'application/json',
                        'Accept': 'application/json'
                    },
                    body: JSON.stringify({
                        accessKey: "sf_077ej49gjha153gk3m6ceecf",
                        subject: "🚨 ALERTA: Proposta Acessada (Bruna Horn - Jardins SP)",
                        name: "Sistema Vision",
                        email: "diretoria@visionsp.com.br",
                        message: "A cliente Bruna Horn acabou de abrir a proposta de CFTV!\n\n👤 Cliente: Bruna Horn\n🔑 Senha Utilizada: " + input + "\n🕒 Horário: " + new Date().toLocaleString('pt-BR')
                    })
                }).catch(error => console.log('Log de segurança disparado.'));

                setTimeout(() => { 
                    lockScreen.style.display = 'none'; 
                    const htmlRoot = document.getElementById('html-root');
                    if(htmlRoot) {
                        htmlRoot.classList.remove('overflow-hidden', 'h-screen');
                        htmlRoot.classList.add('overflow-x-hidden');
                    }
                    document.body.classList.remove('overflow-hidden', 'h-screen');
                }, 700);

            }, 800);

        } else {
            errorMsg.classList.remove('hidden');
            document.getElementById('password-input').style.borderColor = 'rgba(239,68,68,0.5)';
            setTimeout(() => {
                errorMsg.classList.add('hidden');
                document.getElementById('password-input').style.borderColor = '';
            }, 3000);
        }
    }

    // Configuração de Multiplicadores Oficiais de taxas de cartão
    const multipliers = {
        1: 1.0438,
        2: 1.0648,
        3: 1.0754,
        4: 1.0859,
        5: 1.0965,
        6: 1.1071,
        7: 1.1440,
        8: 1.1550,
        9: 1.1662,
        10: 1.1773,
        11: 1.1886,
        12: 1.1999
    };

    const opt1Base = 6222;   // IP Premium POE 8 canais (Sem Nobreak)
    const opt2Base = 7342;   // IP Premium POE + Nobreak 1200VA
    let currentMode = 'avista';

    // Evita valores que terminam em zero (0)
    function avoidZeroEnding(val) {
        val = Math.floor(val);
        if (val % 10 === 0) {
            val += 1;
        }
        return val;
    }

    function formatCurrency(value) {
        return value.toLocaleString('pt-BR', {minimumFractionDigits: 0, maximumFractionDigits: 0});
    }

    function setPaymentMode(mode) {
        currentMode = mode;
        const bg = document.getElementById('toggle-bg');
        const btnPix = document.getElementById('btn-avista');
        const btnParcelado = document.getElementById('btn-parcelado');
        const selectContainer = document.getElementById('installment-container');

        if (mode === 'avista') {
            if (bg) bg.style.transform = 'translateX(0)';
            if (btnPix) {
                btnPix.classList.remove('text-gray-500');
                btnPix.classList.add('text-gray-900');
            }
            if (btnParcelado) {
                btnParcelado.classList.remove('text-zinc-950');
                btnParcelado.classList.add('text-gray-500');
            }
            if (selectContainer) {
                selectContainer.classList.add('opacity-0', 'pointer-events-none');
                setTimeout(() => { selectContainer.classList.add('hidden'); }, 300);
            }
        } else {
            if (bg) bg.style.transform = 'translateX(100%)';
            if (btnParcelado) {
                btnParcelado.classList.remove('text-gray-500');
                btnParcelado.classList.add('text-black');
            }
            if (btnPix) {
                btnPix.classList.remove('text-gray-900');
                btnPix.classList.add('text-gray-500');
            }
            if (selectContainer) {
                selectContainer.classList.remove('hidden');
                setTimeout(() => { selectContainer.classList.remove('opacity-0', 'pointer-events-none'); }, 10);
            }
        }
        updatePrices();
    }

    function updatePrices() {
        const select = document.getElementById('installment-select');
        const inst = parseInt(select.value);
        const factor = multipliers[inst] || 1;

        // Elementos Opção 1 (Básico)
        const labelPay1 = document.getElementById('label-pay-1');
        const priceContainer1 = document.getElementById('price-container-1');
        const breakdown1 = document.getElementById('breakdown-1');
        const btnAprova1 = document.getElementById('btn-aprova-1');

        // Elementos Opção 2 (Recomendado Premium)
        const labelPay2 = document.getElementById('label-pay-2');
        const priceContainer2 = document.getElementById('price-container-2');
        const breakdown2 = document.getElementById('breakdown-2');
        const btnAprova2 = document.getElementById('btn-aprova-2');

        if (currentMode === 'avista') {
            // CÁLCULO OPÇÃO 1 À VISTA
            const sinal1 = avoidZeroEnding(opt1Base * 0.5);
            const saldo1 = avoidZeroEnding(opt1Base * 0.5);
            
            labelPay1.textContent = "À Vista no PIX (Sem Juros)";
            priceContainer1.innerHTML = `
                <span class="text-xs sm:text-lg font-bold text-gray-500">R$</span>
                <span class="text-xl sm:text-3xl md:text-4xl font-black text-gray-900 tracking-tight">${formatCurrency(opt1Base)}</span>
            `;
            breakdown1.innerHTML = `
                <div class="space-y-0.5 text-left text-[7px] sm:text-[10px]">
                    <div class="bg-white border border-gray-150 rounded px-1.5 sm:px-3 py-1 flex justify-between items-center shadow-xs">
                        <span class="text-gray-500 uppercase font-bold text-[5px] sm:text-[8px]">SINAL ATIVAÇÃO (50%)</span>
                        <span class="font-extrabold text-zinc-900">R$ ${formatCurrency(sinal1)}</span>
                    </div>
                    <div class="bg-white border border-gray-150 rounded px-1.5 sm:px-3 py-1 flex justify-between items-center shadow-xs">
                        <span class="text-gray-500 uppercase font-bold text-[5px] sm:text-[8px]">SALDO NA ENTREGA (50%)</span>
                        <span class="font-extrabold text-zinc-900">R$ ${formatCurrency(saldo1)}</span>
                    </div>
                </div>
            `;

            // CÁLCULO OPÇÃO 2 À VISTA
            const sinal2 = avoidZeroEnding(opt2Base * 0.5);
            const saldo2 = avoidZeroEnding(opt2Base * 0.5);

            labelPay2.textContent = "À Vista no PIX (Sem Juros)";
            priceContainer2.innerHTML = `
                <span class="text-xs sm:text-lg font-bold text-gray-500">R$</span>
                <span class="text-xl sm:text-3xl md:text-4xl font-black text-gray-900 tracking-tight">${formatCurrency(opt2Base)}</span>
            `;
            breakdown2.innerHTML = `
                <div class="space-y-0.5 text-left text-[7px] sm:text-[10px]">
                    <div class="bg-white border border-gray-150 rounded px-1.5 sm:px-3 py-1 flex justify-between items-center shadow-xs">
                        <span class="text-gray-500 uppercase font-bold text-[5px] sm:text-[8px]">SINAL ATIVAÇÃO (50%)</span>
                        <span class="font-extrabold text-zinc-900">R$ ${formatCurrency(sinal2)}</span>
                    </div>
                    <div class="bg-white border border-gray-150 rounded px-1.5 sm:px-3 py-1 flex justify-between items-center shadow-xs">
                        <span class="text-gray-500 uppercase font-bold text-[5px] sm:text-[8px]">SALDO NA ENTREGA (50%)</span>
                        <span class="font-extrabold text-zinc-900">R$ ${formatCurrency(saldo2)}</span>
                    </div>
                </div>
            `;

            btnAprova1.href = `https://wa.me/5511930816696?text=${encodeURIComponent("Olá Glícia, analisei a proposta e gostaria de aprovar a Opção 1 (06 Câmeras IP POE sem Nobreak) à vista de R$ " + formatCurrency(opt1Base) + " no PIX.")}`;
            btnAprova2.href = `https://wa.me/5511930816696?text=${encodeURIComponent("Olá Glícia, analisei a proposta e gostaria de aprovar a Opção 2 (06 Câmeras IP POE + Nobreak 1200VA) à vista de R$ " + formatCurrency(opt2Base) + " no PIX.")}`;

        } else {
            // CÁLCULO OPÇÃO 1 PARCELADO
            const totalOpt1 = avoidZeroEnding(opt1Base * factor);
            const installmentValue1 = avoidZeroEnding(totalOpt1 / inst);

            labelPay1.textContent = "Parcelado no Cartão de Crédito";
            priceContainer1.innerHTML = `
                <span class="text-[8px] sm:text-lg font-bold text-brand-yellow mr-1">${inst}x de</span>
                <span class="text-xs sm:text-lg font-bold text-gray-500">R$</span>
                <span class="text-xl sm:text-3xl md:text-4xl font-black text-gray-900 tracking-tight">${formatCurrency(installmentValue1)}</span>
            `;
            breakdown1.innerHTML = `
                <div class="bg-white border border-gray-150 rounded px-2 py-1.5 text-center text-[7px] sm:text-[10px] shadow-xs">
                    <span class="text-gray-400 uppercase font-bold">TOTAL PARCELADO (COM TAXAS):</span>
                    <span class="font-extrabold text-zinc-950 block">R$ ${formatCurrency(totalOpt1)}</span>
                </div>
            `;

            // CÁLCULO OPÇÃO 2 PARCELADO
            const totalOpt2 = avoidZeroEnding(opt2Base * factor);
            const installmentValue2 = avoidZeroEnding(totalOpt2 / inst);

            labelPay2.textContent = "Parcelado no Cartão de Crédito";
            priceContainer2.innerHTML = `
                <span class="text-[8px] sm:text-lg font-bold text-brand-yellow mr-1">${inst}x de</span>
                <span class="text-xs sm:text-lg font-bold text-gray-500">R$</span>
                <span class="text-xl sm:text-3xl md:text-4xl font-black text-gray-900 tracking-tight">${formatCurrency(installmentValue2)}</span>
            `;
            breakdown2.innerHTML = `
                <div class="bg-white border border-gray-150 rounded px-2 py-1.5 text-center text-[7px] sm:text-[10px] shadow-xs">
                    <span class="text-gray-400 uppercase font-bold">TOTAL PARCELADO (COM TAXAS):</span>
                    <span class="font-extrabold text-zinc-950 block">R$ ${formatCurrency(totalOpt2)}</span>
                </div>
            `;

            btnAprova1.href = `https://wa.me/5511930816696?text=${encodeURIComponent("Olá Glícia, analisei a proposta e gostaria de aprovar a Opção 1 (06 Câmeras IP POE sem Nobreak) parcelada em " + inst + "x de R$ " + formatCurrency(installmentValue1) + " no cartão.")}`;
            btnAprova2.href = `https://wa.me/5511930816696?text=${encodeURIComponent("Olá Glícia, analisei a proposta e gostaria de aprovar a Opção 2 (06 Câmeras IP POE + Nobreak 1200VA) parcelada em " + inst + "x de R$ " + formatCurrency(installmentValue2) + " no cartão.")}`;
        }
        initIcons();
    }

    window.addEventListener("load", () => {
        setPaymentMode('avista');
    });

    // Animação de entrada
    const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) entry.target.classList.add('active');
        });
    }, { threshold: 0.05 });
    document.querySelectorAll('.reveal').forEach(el => observer.observe(el));

    // Eventos de Scroll
    window.addEventListener('scroll', () => {
        const winScroll = document.documentElement.scrollTop || document.body.scrollTop;
        const height = document.documentElement.scrollHeight - document.documentElement.clientHeight;
        const scrolled = (winScroll / height) * 100;
        const progressBar = document.getElementById("progress-bar");
        if(progressBar) {
            progressBar.style.width = scrolled + "%";
        }

        const navbar = document.getElementById('navbar');
        if (window.scrollY > 50) {
            if(navbar) navbar.classList.add('shadow-md');
        } else {
            if(navbar) navbar.classList.remove('shadow-md');
        }
    });

    // Controle de Áudio do Vídeo do Hero
    document.addEventListener("DOMContentLoaded", function() {
        const video = document.getElementById("vision-video");
        const overlay = document.getElementById("unmute-overlay");
        if (video && overlay) {
            overlay.addEventListener("click", function(e) {
                e.stopPropagation(); 
                video.muted = false;
                video.loop = true; 
                video.currentTime = 0;
                video.play().catch(err => {
                    console.warn("Autoplay impedido pelo navegador", err);
                });
                overlay.style.opacity = "0";
                setTimeout(() => { overlay.style.display = "none"; }, 500); 

                if (window.clarity) {
                    window.clarity("event", "Video_Assistido_Vision");
                }
            });
            video.addEventListener("click", function() {
                if (overlay.style.display === "none") {
                    if (video.paused) { video.play(); } else { video.pause(); }
                }
            });
        }
    });
</script>
