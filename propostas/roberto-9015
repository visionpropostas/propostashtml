                    <span class="text-4xl md:text-5xl font-black text-gray-900 tracking-tight mb-6">R$ ${formatCurrency(p1)}</span>
                    
                    <div class="w-full space-y-3">
                        <div class="bg-white border border-gray-200 rounded-xl py-4 flex flex-col items-center justify-center relative overflow-hidden shadow-sm">
