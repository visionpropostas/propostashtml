            if(datacenter) datacenter.style.opacity = '0.5';
            if(desc) desc.innerHTML = "Backbone (Rede): Infraestrutura de cabos CAT6 guiando energia e dados com estabilidade total.";
        } else if (layerName === 'datacenter') {
