        const datacenter = document.getElementById('svg-datacenter');
        const desc = document.getElementById('topologia-desc');

        // Reset all
        if(building) building.style.opacity = '1';
        if(network) network.style.opacity = '1';
        if(cameras) cameras.style.opacity = '1';
        if(datacenter) datacenter.style.opacity = '1';

        if (layerName === 'cameras') {
            if(building) building.style.opacity = '0.3';
            if(network) network.style.opacity = '0.1';
            if(datacenter) datacenter.style.opacity = '0.1';
