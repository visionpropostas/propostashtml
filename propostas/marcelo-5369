        const activeBadge = document.getElementById('active-gallery-badge');
        
        if (!activeImg || !activeTitle || !activeBadge) return;

        // Animação suave de fade
        activeImg.style.opacity = "0.2";
        
        setTimeout(() => {
            const selected = galleryItems[index];
            activeImg.src = selected.url;
            activeTitle.textContent = selected.title;
            activeBadge.textContent = selected.badge;
            activeImg.style.opacity = "1";
        }, 150);

        // Atualizar estilos dos botões
        document.querySelectorAll('.thumbnail-btn').forEach(btn => {
            btn.classList.remove('ring-2', 'ring-brand-yellow', 'border-transparent');
            btn.classList.add('border-zinc-800', 'opacity-60');
        });
        
        buttonEl.classList.remove('border-zinc-800', 'opacity-60');
        buttonEl.classList.add('ring-2', 'ring-brand-yellow', 'border-transparent');
    }

