    // FORMATA OS VALORES NUMÉRICOS PARA EXIBIÇÃO SEM DECIMAIS OU CENTAVOS (MENOR IMPACTO VISUAL)
    function formatCurrency(value) {
        return Math.round(value).toLocaleString('pt-BR', { maximumFractionDigits: 0 });
    }

    // ATUALIZA DINAMICAMENTE O ENDEREÇO DE LINK E MENSAGEM DO WHATSAPP
    function updateWhatsAppLink() {
        const btnLink = document.getElementById('btn-aprova-link');
        if (!btnLink) return;

        let message = '';
        const basePriceVal = prices.basePrice;

        if (currentMode === 'avista') {
            message = `Olá Glícia, analisei a proposta do Condomínio Mont Parnasse e gostaríamos de aprovar o projeto com pagamento à Vista de R$ ${formatCurrency(basePriceVal)} via PIX.`;
        } else {
            const select = document.getElementById('installment-select');
            const installments = select ? select.value : '12';
            const totalWithRate = prices.rates[installments] || basePriceVal;
            const installmentValue = totalWithRate / parseInt(installments);
            message = `Olá Glícia, analisei a proposta do Condomínio Mont Parnasse e gostaríamos de aprovar o projeto parcelado em ${installments}x de R$ ${formatCurrency(installmentValue)} no cartão de crédito.`;
        }

        btnLink.href = "https://wa.me/5511930816696?text=" + encodeURIComponent(message);
    }

