<script>
    // INICIALIZAÇÃO DOS ÍCONES LUCIDE
    lucide.createIcons();

    // BASE DE DADOS DO PROJETO CORPORATIVO JMARTINS COM FONTE ININTERRUPTA OBRIGATÓRIA
    const configData = {
