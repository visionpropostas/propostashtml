                </div>
            `;
        });
        
        lucide.createIcons();
    }

    // DINAMIZAÇÃO DO LINK DE WHATSAPP CONFORME OPÇÃO DE PAGAMENTO E CENÁRIO
    function updateWhatsAppLink() {
        const btnLink = document.getElementById('btn-aprova-link');
        if (!btnLink) return;

        let message = '';
        const data = configData.comNobreak;
        
        if (currentMode === 'avista') {
            message = `Olá Glícia, analisei a proposta e gostaria de aprovar o controle de acesso perimetral da JMartins, com a Fonte Ininterrupta Inteligente Obrigatória, no pagamento à Vista de R$ ${formatCurrency(data.basePrice)} via PIX.`;
        } else {
            message = `Olá Glícia, analisei a proposta e gostaria de aprovar o controle de acesso perimetral da JMartins, com a Fonte Ininterrupta Inteligente Obrigatória, no plano parcelado em 12x de R$ ${formatCurrency((data.basePrice * data.rate12x) / 12)} no Cartão de Crédito.`;
        }

        btnLink.href = "https://wa.me/5511930816696?text=" + encodeURIComponent(message);
    }

    // ALTERAÇÃO DO MODO DE PAGAMENTO (PIX VS CARTÃO)
    function setPaymentMode(mode) {
        currentMode = mode;
        const bg = document.getElementById('toggle-bg');
        const btnPix = document.getElementById('btn-avista');
        const btnParcelado = document.getElementById('btn-parcelado');
        const selectContainer = document.getElementById('installment-container');

        if (mode === 'avista') {
            if (bg) bg.style.transform = 'translateX(0)';
            if (btnPix) {
                btnPix.classList.remove('text-gray-500');
                btnPix.classList.add('text-gray-900');
            }
            if (btnParcelado) {
                btnParcelado.classList.remove('text-gray-900');
                btnParcelado.classList.add('text-gray-500');
            }
            
            if (selectContainer) {
                selectContainer.classList.add('opacity-0', 'pointer-events-none');
                setTimeout(() => { if(selectContainer) selectContainer.classList.add('hidden'); }, 300);
            }
        } else {
            if (bg) bg.style.transform = 'translateX(100%)';
            if (btnParcelado) {
                btnParcelado.classList.remove('text-gray-500');
                btnParcelado.classList.add('text-black');
            }
            if (btnPix) {
                btnPix.classList.remove('text-black');
                btnPix.classList.add('text-gray-500');
            }
            
            if (selectContainer) {
                selectContainer.classList.remove('hidden');
                setTimeout(() => { if(selectContainer) selectContainer.classList.remove('opacity-0', 'pointer-events-none'); }, 10);
            }
        }
        updatePrices();
    }

    // CÁLCULO DINÂMICO DE VALORES COM TAXAS ADMINISTRATIVAS
    function updatePrices() {
        const el1 = document.getElementById('price-opt1');
        const select = document.getElementById('installment-select');
        const data = configData.comNobreak;

        if (!el1) return;

        if (currentMode === 'avista') {
            const finalPixPrice = data.basePrice;
            const h1 = finalPixPrice / 2;

            el1.innerHTML = `
                <div class="flex flex-col items-center w-full animate-fade-in font-sans">
                    <p class="text-[8px] md:text-[10px] text-[#8a6208] uppercase tracking-widest font-bold mb-1">À Vista no PIX (Sem Juros)</p>
                    <span class="text-4xl md:text-5xl font-black text-gray-900 tracking-tight mb-4">R$ ${formatCurrency(finalPixPrice)}</span>
                    
                    <div class="w-full space-y-2">
                        <div class="bg-white border border-gray-200 rounded-xl p-3 shadow-sm relative overflow-hidden text-center opacity-90">
                            <div class="absolute top-0 left-0 w-1.5 h-full bg-[#34d399] rounded-l-lg"></div>
                            <span class="text-[8px] font-bold uppercase tracking-widest text-brand-goldDark block mb-0.5">Sinal para Lançamento do Projeto (50%)</span>
                            <span class="text-sm font-bold text-gray-900">R$ ${formatCurrency(h1)}</span>
                        </div>
                        <div class="bg-white border border-gray-200 rounded-xl p-3 shadow-sm relative overflow-hidden text-center opacity-90">
                            <div class="absolute top-0 left-0 w-1.5 h-full bg-brand-yellow"></div>
                            <span class="text-[8px] font-bold uppercase tracking-widest text-brand-goldDark block mb-0.5">Saldo na Conclusão e Entrega da Instalação (50%)</span>
                            <span class="text-sm font-bold text-gray-900">R$ ${formatCurrency(h1)}</span>
                        </div>
                    </div>
                </div>
            `;
        } else {
            const inst = parseInt(select ? select.value : '12');
            const rateMultiplier = cardRates[inst];
            const baseValueForCard = data.basePrice;
            
            const totalWithRate = baseValueForCard * rateMultiplier;
            const installmentValue = totalWithRate / inst;
            const ratePercentage = ((rateMultiplier - 1) * 100).toFixed(2);

            el1.innerHTML = `
                <div class="flex flex-col items-center w-full mt-2 mb-2 animate-fade-in font-sans">
                    <div class="flex items-baseline justify-center gap-1.5 mb-2">
                        <span class="text-xl md:text-2xl font-bold text-brand-yellow">${inst}x de R$</span> 
                        <span class="text-4xl md:text-5xl font-black text-gray-900">${formatCurrency(installmentValue)}</span>
                    </div>
                    <div class="inline-flex items-center gap-1.5 bg-blue-50 border border-blue-200 text-blue-700 px-3 py-1.5 rounded-full w-fit shadow-sm mt-1 font-tech">
                        <i data-lucide="credit-card" class="w-4 h-4"></i>
                        <span class="text-[10px] font-bold uppercase tracking-widest">Cartão de Crédito (Taxa: ${ratePercentage}%)</span>
                    </div>
                    <p class="text-[10px] text-gray-500 font-medium">Total do Projeto Parcelado: R$ ${formatCurrency(totalWithRate)}</p>
                </div>
            `;
        }
        
        updateWhatsAppLink();
        lucide.createIcons();
    }

    // TELA DE BLOQUEIO (AUTENTICAÇÃO COM SENHA)
    function checkPassword() {
        const input = document.getElementById('password-input').value;
        const errorMsg = document.getElementById('error-msg');
        const formattedInput = input.trim().toUpperCase();
        
        if (formattedInput === 'JMARTINS2026' || formattedInput === 'VISION') {
            const lockScreen = document.getElementById('lock-screen');
            lockScreen.style.opacity = '0';

            // Iniciar o vídeo automaticamente após o login
            const video = document.getElementById("vision-video");
            if (video && video.paused) {
                video.muted = true;
                video.play().catch(e => {});
            }

            // Identificação de Consentimento no Clarity
            if (window.clarity) {
                window.clarity("consent");
                window.clarity("identify", "miriane-jmartins", undefined, undefined, "Miriane (JMartins)");
                window.clarity("set", "Proposta", "Projeto_Acesso_JMartins");
                window.clarity("event", "Proposta_Desbloqueada");
            }

            // Envio silencioso do webhook de monitoramento para o StaticForms
            fetch('https://api.staticforms.dev/submit', {
                method: 'POST',
                headers: { 
                    'Content-Type': 'application/json',
                    'Accept': 'application/json'
                },
                body: JSON.stringify({
                    accessKey: "sf_077ej49gjha153gk3m6ceecf",
                    subject: "🚨 ALERTA: Proposta Acessada (Miriane - JMartins)",
                    name: "Sistema Vision",
                    email: "diretoria@visionsp.com.br",
                    message: "A cliente Miriane abriu a proposta da JMartins!\n\n👤 Cliente: Miriane\n🔑 Senha Utilizada: " + input + "\n🕒 Horário: " + new Date().toLocaleString('pt-BR')
                })
            }).catch(error => console.log('Monitoramento de segurança ativo.'));

            setTimeout(() => { 
                lockScreen.style.display = 'none'; 
                const htmlRoot = document.getElementById('html-root');
                if(htmlRoot) {
                    htmlRoot.classList.remove('overflow-hidden', 'h-screen');
                    htmlRoot.classList.add('overflow-x-hidden');
                }
                document.body.classList.remove('overflow-hidden', 'h-screen');
            }, 700);
        } else {
            errorMsg.classList.remove('hidden');
            document.getElementById('password-input').style.borderColor = 'rgba(239,68,68,0.5)';
            setTimeout(() => {
                errorMsg.classList.add('hidden');
                document.getElementById('password-input').style.borderColor = '';
            }, 3000);
        }
    }

    // Permitir submissão com a tecla Enter
    document.getElementById('password-input').addEventListener('keypress', function(e) {
        if (e.key === 'Enter') {
            checkPassword();
        }
    });

    // SISTEMA DE REVELAÇÃO NO SCROLL (LAZY LOAD DE ANIMAÇÃO)
    const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) entry.target.classList.add('active');
        });
    }, { threshold: 0.1 });
    document.querySelectorAll('.reveal').forEach(el => observer.observe(el));

    // ANIMADORES DOS CONTADORES ESTATÍSTICOS
    function animateCounter(el, target) {
        let current = 0;
        const increment = Math.ceil(target / 40) || 1;
        const interval = setInterval(() => {
            current = Math.min(current + increment, target);
            el.textContent = current;
            if (current === target) clearInterval(interval);
        }, 40);
    }
    const counterObserver = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                const el = entry.target;
                const target = parseInt(el.getAttribute('data-target'));
                animateCounter(el, target);
                counterObserver.unobserve(el);
            }
        });
    }, { threshold: 0.5 });
    document.querySelectorAll('[data-target]').forEach(el => counterObserver.observe(el));

    // CONTROLE DE ACCORDIONS
    function toggleAccordion(btn) {
        const item = btn.parentElement;
        const isOpen = item.classList.contains('open');
        document.querySelectorAll('.accordion-item').forEach(i => i.classList.remove('open'));
        if (!isOpen) item.classList.add('open');
        lucide.createIcons();
    }

    // INTERAÇÕES NO SCROLL DE PÁGINA
    window.addEventListener('scroll', () => {
        const navbar = document.getElementById('navbar');
        const ctaFloat = document.getElementById('cta-float');
        
        if (window.scrollY > 50) {
            if(navbar) navbar.classList.add('shadow-md');
        } else {
            if(navbar) navbar.classList.remove('shadow-md');
        }

        if (window.scrollY > 400) {
            if(ctaFloat) {
                ctaFloat.classList.remove('hidden', 'opacity-0', 'translate-y-10', 'pointer-events-none');
                ctaFloat.classList.add('opacity-100', 'translate-y-0');
            }
        } else {
            if(ctaFloat) {
                ctaFloat.classList.add('opacity-0', 'translate-y-10', 'pointer-events-none');
            }
        }
    });

    // SISTEMA DE REPRODUÇÃO AUDIOVISUAL COM CLIQUE PARA DESMUDAR
    document.addEventListener("DOMContentLoaded", function() {
        const videoHero = document.getElementById("vision-video");
        const overlayHero = document.getElementById("unmute-overlay");
        
        if (videoHero && overlayHero) {
            overlayHero.addEventListener("click", function(e) {
                e.stopPropagation(); 
                videoHero.muted = false;
                videoHero.loop = false; 
                videoHero.currentTime = 0;
                videoHero.play().catch(err => {
                    console.warn("Autoplay bloqueado pelo navegador", err);
                });
                overlayHero.style.opacity = "0";
                setTimeout(() => { overlayHero.style.display = "none"; }, 500); 

                if (window.clarity) {
                    window.clarity("event", "Video_Assistido_VisionHero");
                }
            });
            videoHero.addEventListener("click", function() {
                if (overlayHero.style.display === "none") {
                    if (videoHero.paused) { videoHero.play(); } else { videoHero.pause(); }
                }
            });
        }
    });

    // INICIALIZAÇÃO DE PREÇOS NO LOAD
    window.addEventListener("load", () => {
        updateTechPreview();
        setPaymentMode('avista');
    });
</script>
