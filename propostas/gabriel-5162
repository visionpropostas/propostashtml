                if(errorMsg) errorMsg.classList.add('hidden');
                if(passInput) passInput.style.borderColor = '';
            }, 3000);
        }
    }

    const passInputElem = document.getElementById('password-input');
    if(passInputElem) {
        passInputElem.addEventListener('keypress', function(e) {
            if (e.key === 'Enter') checkPassword();
        });
    }

    // REVEAL ON SCROLL
    const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) entry.target.classList.add('active');
        });
    }, { threshold: 0.1 });
    document.querySelectorAll('.reveal').forEach(el => observer.observe(el));

    // ANIMATE COUNTERS
    function animateCounter(el, target) {
        let current = 0;
        const increment = Math.ceil(target / 40) || 1;
        const interval = setInterval(() => {
            current = Math.min(current + increment, target);
            el.textContent = current;
            if (current === target) clearInterval(interval);
        }, 40);
    }
    const counterObserver = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                const el = entry.target;
                const target = parseInt(el.getAttribute('data-target'));
                animateCounter(el, target);
                counterObserver.unobserve(el);
            }
        });
    }, { threshold: 0.5 });
    document.querySelectorAll('[data-target]').forEach(el => counterObserver.observe(el));

    // ACCORDION
    function toggleAccordion(btn) {
        const item = btn.parentElement;
        const isOpen = item.classList.contains('open');
        document.querySelectorAll('.accordion-item').forEach(i => i.classList.remove('open'));
        if (!isOpen) item.classList.add('open');
        lucide.createIcons();
    }

    // NAVBAR E CTA SCROLL
    window.addEventListener('scroll', () => {
        const navbar = document.getElementById('navbar');
        const ctaFloat = document.getElementById('cta-float');
        
        if(navbar) {
            if (window.scrollY > 50) {
                navbar.classList.add('shadow-md');
            } else {
                navbar.classList.remove('shadow-md');
            }
        }

        if(ctaFloat) {
            if (window.scrollY > 400) {
                ctaFloat.classList.remove('hidden');
                ctaFloat.classList.remove('opacity-0', 'translate-y-10', 'pointer-events-none');
                ctaFloat.classList.add('opacity-100', 'translate-y-0');
            } else {
                ctaFloat.classList.add('opacity-0', 'translate-y-10', 'pointer-events-none');
            }
        }
    });

    // VIDEO UNMUTE
    document.addEventListener("DOMContentLoaded", function() {
        const video = document.getElementById("vision-video");
        const overlay = document.getElementById("unmute-overlay");
        if (video && overlay) {
            overlay.addEventListener("click", function(e) {
                e.stopPropagation(); 
                video.muted = false;
                video.loop = false; 
                video.currentTime = 0;
                video.play();
                overlay.style.opacity = "0";
                setTimeout(() => { overlay.style.display = "none"; }, 500); 
            });
            video.addEventListener("click", function() {
                if (overlay.style.display === "none") {
                    if (video.paused) { video.play(); } else { video.pause(); }
                }
            });
        }
    });
</script>
