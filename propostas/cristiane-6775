                    <span class="text-xl md:text-3xl font-extrabold text-gray-900 mb-2">R$ ${formatCurrency(basePrice1)}</span>
                    <div class="w-full space-y-1.5 md:space-y-2 mt-1 md:mt-2">
                        <div class="bg-white border border-gray-200 rounded-md md:rounded-lg p-1.5 md:p-2 shadow-sm relative overflow-hidden text-center">
                            <div class="absolute top-0 left-0 w-1 h-full bg-emerald-400"></div>
                            <span class="text-[7px] md:text-[9px] font-bold uppercase tracking-widest text-gray-500 block mb-0.5">Sinal 50%</span>
                            <span class="font-bold text-gray-900 text-[10px] md:text-xs">R$ ${formatCurrency(h1)}</span>
                        </div>
                        <div class="bg-white border border-gray-200 rounded-md md:rounded-lg p-1.5 md:p-2 shadow-sm relative overflow-hidden text-center">
                            <div class="absolute top-0 left-0 w-1 h-full bg-brand-yellow"></div>
                            <span class="text-[7px] md:text-[9px] font-bold uppercase tracking-widest text-gray-500 block mb-0.5">Na Entrega</span>
