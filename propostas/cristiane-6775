            `;
        } else {
            // Cartão de Crédito com taxas reais InfinitePay
            const inst = parseInt(select.value);
            const rateMultiplier = cardRates[inst];
            
            const t1 = basePrice1 * rateMultiplier;
            const t2 = basePrice2 * rateMultiplier;

            const val1 = t1 / inst;
            const val2 = t2 / inst;

            elPrice1.innerHTML = `
                <div class="flex items-baseline justify-center gap-1 mb-1">
                    <span class="text-xs md:text-lg font-bold text-gray-500">${inst}x</span> 
                    <span class="text-xl md:text-3xl font-extrabold text-gray-900">R$ ${formatCurrency(val1)}</span>
                </div>
                <div class="inline-flex items-center gap-1 md:gap-1.5 bg-blue-50 border border-blue-200 text-blue-700 px-2 md:px-3 py-1 md:py-1.5 rounded-full w-fit shadow-sm mt-1 mb-2">
