                        </div>
                        <div class="bg-white border border-brand-yellow/30 rounded-md md:rounded-lg p-1.5 md:p-2 shadow-sm relative overflow-hidden text-center">
                            <div class="absolute top-0 left-0 w-1 h-full bg-brand-yellow"></div>
                            <span class="text-[7px] md:text-[9px] font-bold uppercase tracking-widest text-brand-goldDark block mb-0.5">Na Entrega</span>
                            <span class="font-bold text-gray-900 text-[10px] md:text-xs">R$ ${formatCurrency(h2)}</span>
                        </div>
                    </div>
