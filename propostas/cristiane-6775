                btnParcelado.classList.add('text-gray-500');
            }
            const selectContainer = document.getElementById('installment-container');
            if (selectContainer) {
                selectContainer.classList.add('opacity-0', 'pointer-events-none');
                setTimeout(() => { if(selectContainer) selectContainer.classList.add('hidden'); }, 300);
            }
        } else {
            if (bg) bg.style.transform = 'translateX(100%)';
            if (btnParcelado) {
                btnParcelado.classList.remove('text-gray-500');
                btnParcelado.classList.add('text-gray-900');
            }
            if (btnPix) {
                btnPix.classList.remove('text-gray-900');
                btnPix.classList.add('text-gray-500');
            }
            const selectContainer = document.getElementById('installment-container');
            if (selectContainer) {
                selectContainer.classList.remove('hidden');
                setTimeout(() => { if(selectContainer) selectContainer.classList.remove('opacity-0', 'pointer-events-none'); }, 10);
            }
        }
        updatePrices();
    }

    function updatePrices() {
        const elPrice1 = document.getElementById('price-opt1');
        const elPrice2 = document.getElementById('price-opt2');
        const select = document.getElementById('installment-select');

        if (!elPrice1 || !elPrice2) return;

        if (currentMode === 'avista') {
            const h1 = basePrice1 / 2;
            const h2 = basePrice2 / 2;

            elPrice1.innerHTML = `
                <div class="flex flex-col items-center w-full transition-all duration-300">
                    <div class="flex items-baseline justify-center gap-1.5 mb-4 md:mb-6 mt-2">
                        <span class="text-xl md:text-2xl font-bold text-gray-400">R$</span>
                        <span class="text-3xl md:text-5xl font-extrabold text-gray-900 tracking-tighter leading-none">${formatCurrency(basePrice1)}</span>
                    </div>
                    <div class="w-full space-y-2 mt-2">
                        <div class="bg-white border border-gray-200 rounded-lg p-3 shadow-sm relative overflow-hidden flex justify-between items-center">
                            <div class="absolute top-0 left-0 w-1 h-full bg-emerald-400"></div>
                            <span class="text-[9px] md:text-[10px] font-bold uppercase tracking-widest text-gray-500 ml-2">Sinal 50%</span>
                            <span class="font-extrabold text-gray-900 text-xs md:text-sm">R$ ${formatCurrency(h1)}</span>
                        </div>
                        <div class="bg-white border border-gray-200 rounded-lg p-3 shadow-sm relative overflow-hidden flex justify-between items-center">
                            <div class="absolute top-0 left-0 w-1 h-full bg-brand-yellow"></div>
                            <span class="text-[9px] md:text-[10px] font-bold uppercase tracking-widest text-gray-500 ml-2">Na Entrega</span>
                            <span class="font-extrabold text-gray-900 text-xs md:text-sm">R$ ${formatCurrency(h1)}</span>
                        </div>
                    </div>
                </div>
            `;
            
            elPrice2.innerHTML = `
                <div class="flex flex-col items-center w-full transition-all duration-300">
                    <div class="flex items-baseline justify-center gap-1.5 mb-4 md:mb-6 mt-2">
                        <span class="text-xl md:text-2xl font-bold text-gray-400">R$</span>
                        <span class="text-3xl md:text-5xl font-extrabold text-gray-900 tracking-tighter leading-none">${formatCurrency(basePrice2)}</span>
                    </div>
                    <div class="w-full space-y-2 mt-2">
                        <div class="bg-white border border-brand-yellow/30 rounded-lg p-3 shadow-sm relative overflow-hidden flex justify-between items-center">
                            <div class="absolute top-0 left-0 w-1 h-full bg-emerald-400"></div>
                            <span class="text-[9px] md:text-[10px] font-bold uppercase tracking-widest text-brand-goldDark ml-2">Sinal 50%</span>
                            <span class="font-extrabold text-gray-900 text-xs md:text-sm">R$ ${formatCurrency(h2)}</span>
                        </div>
                        <div class="bg-white border border-brand-yellow/30 rounded-lg p-3 shadow-sm relative overflow-hidden flex justify-between items-center">
                            <div class="absolute top-0 left-0 w-1 h-full bg-brand-yellow"></div>
                            <span class="text-[9px] md:text-[10px] font-bold uppercase tracking-widest text-brand-goldDark ml-2">Na Entrega</span>
                            <span class="font-extrabold text-gray-900 text-xs md:text-sm">R$ ${formatCurrency(h2)}</span>
                        </div>
                    </div>
                </div>
            `;
        } else {
            // Financiamento real de juros do integrador
            const inst = parseInt(select.value);
            const rateMultiplier = cardRates[inst];
            
            const t1 = basePrice1 * rateMultiplier;
            const t2 = basePrice2 * rateMultiplier;

            const val1 = t1 / inst;
            const val2 = t2 / inst;

            elPrice1.innerHTML = `
                <div class="flex flex-col items-center w-full transition-all duration-300">
                    <div class="flex items-baseline justify-center gap-1.5 mb-4 mt-2">
                        <span class="text-xl md:text-2xl font-bold text-gray-400">${inst}x</span> 
                        <span class="text-3xl md:text-5xl font-extrabold text-gray-900 tracking-tighter leading-none">${formatCurrency(val1)}</span>
                    </div>
                    <div class="bg-white border border-gray-200 rounded-lg p-3 shadow-sm flex items-center justify-between w-full mb-3">
                        <div class="flex flex-col items-start text-left">
                            <span class="text-[8px] md:text-[9px] font-bold uppercase tracking-widest text-gray-500 mb-0.5">Total Financiado</span>
                            <span class="font-extrabold text-gray-900 text-xs md:text-sm">R$ ${formatCurrency(t1)}</span>
                        </div>
                        <i data-lucide="credit-card" class="w-5 h-5 text-gray-400"></i>
                    </div>
                </div>
            `;
            
            elPrice2.innerHTML = `
                <div class="flex flex-col items-center w-full transition-all duration-300">
                    <div class="flex items-baseline justify-center gap-1.5 mb-4 mt-2">
                        <span class="text-xl md:text-2xl font-bold text-gray-400">${inst}x</span> 
                        <span class="text-3xl md:text-5xl font-extrabold text-gray-900 tracking-tighter leading-none">${formatCurrency(val2)}</span>
                    </div>
                    <div class="bg-white border border-brand-yellow/30 rounded-lg p-3 shadow-sm flex items-center justify-between w-full mb-3">
                        <div class="flex flex-col items-start text-left">
                            <span class="text-[8px] md:text-[9px] font-bold uppercase tracking-widest text-brand-goldDark mb-0.5">Total Financiado</span>
                            <span class="font-extrabold text-gray-900 text-xs md:text-sm">R$ ${formatCurrency(t2)}</span>
                        </div>
                        <i data-lucide="credit-card" class="w-5 h-5 text-brand-yellow"></i>
                    </div>
                </div>
            `;
        }
        lucide.createIcons();
    }

    // Scroll Animations
    const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                entry.target.classList.add('active');
            }
        });
    }, { threshold: 0.1 });
    document.querySelectorAll('.reveal').forEach(el => observer.observe(el));

    // Números Dinâmicos
    function animateCounter(el, target) {
        let current = 0;
        const increment = Math.ceil(target / 40) || 1;
        const interval = setInterval(() => {
            current = Math.min(current + increment, target);
            el.textContent = current;
            if (current === target) clearInterval(interval);
        }, 40);
    }
    const counterObserver = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                const el = entry.target;
                const target = parseInt(el.getAttribute('data-target'));
                animateCounter(el, target);
                counterObserver.unobserve(el);
            }
        });
    }, { threshold: 0.5 });
    document.querySelectorAll('[data-target]').forEach(el => counterObserver.observe(el));

    // Accordion da FAQ
    function toggleAccordion(btn) {
        const item = btn.parentElement;
        const isOpen = item.classList.contains('open');
        document.querySelectorAll('.accordion-item').forEach(i => i.classList.remove('open'));
        if (!isOpen) item.classList.add('open');
        lucide.createIcons();
    }

    // Scroll Navbar e Botão Flutuante
    window.addEventListener('scroll', () => {
        const navbar = document.getElementById('navbar');
        const ctaFloat = document.getElementById('cta-float');
        
        if (window.scrollY > 50) {
            if(navbar) navbar.classList.add('shadow-md');
        } else {
            if(navbar) navbar.classList.remove('shadow-md');
        }

        if (window.scrollY > 400) {
            if(ctaFloat) {
                ctaFloat.classList.remove('hidden', 'opacity-0', 'translate-y-10', 'pointer-events-none');
                ctaFloat.classList.add('opacity-100', 'translate-y-0');
            }
        } else {
            if(ctaFloat) {
                ctaFloat.classList.remove('opacity-100', 'translate-y-0');
                ctaFloat.classList.add('opacity-0', 'translate-y-10', 'pointer-events-none');
            }
        }
    });

    // Controladores de Áudio do Mockup
    document.addEventListener("DOMContentLoaded", function() {
        function setupVideo(videoId, overlayId) {
            const video = document.getElementById(videoId);
            const overlay = document.getElementById(overlayId);
            if (video && overlay) {
                overlay.addEventListener("click", function(e) {
                    e.stopPropagation(); 
                    video.muted = false;
                    video.loop = false; 
                    video.currentTime = 0;
                    video.play();
                    overlay.style.opacity = "0";
                    setTimeout(() => { overlay.style.display = "none"; }, 500); 

                    if (window.clarity) {
                        window.clarity("event", "Video_Assistido_" + videoId);
                    }
                });
                video.addEventListener("click", function() {
                    if (overlay.style.display === "none") {
                        if (video.paused) { video.play(); } else { video.pause(); }
                    }
                });
            }
        }

        setupVideo("vision-video", "unmute-overlay");
    });
</script>
