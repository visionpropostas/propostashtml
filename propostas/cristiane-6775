            elPrice2.innerHTML = `
                <div class="flex items-baseline justify-center gap-1 mb-1">
                    <span class="text-xs md:text-lg font-bold text-brand-yellow">${inst}x</span> 
                    <span class="text-xl md:text-3xl font-extrabold text-gray-900">R$ ${formatCurrency(val2)}</span>
                </div>
                <div class="inline-flex items-center gap-1 md:gap-1.5 bg-blue-50 border border-blue-200 text-blue-700 px-2 md:px-3 py-1 md:py-1.5 rounded-full w-fit shadow-sm mt-1 mb-2">
                    <i data-lucide="credit-card" class="w-2.5 h-2.5 md:w-3 md:h-3"></i>
                    <span class="text-[7px] md:text-[9px] font-bold uppercase tracking-widest">Cartão de Crédito</span>
                </div>
                <p class="text-[8px] md:text-[10px] text-gray-600 font-medium">Total a prazo (com taxas): R$ ${formatCurrency(t2)}</p>
            `;
        }
        lucide.createIcons();
    }

    // REVEAL ON SCROLL
    const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                entry.target.classList.add('active');
            }
        });
    }, { threshold: 0.1 });
    document.querySelectorAll('.reveal').forEach(el => observer.observe(el));

    // ANIMATE COUNTERS
    function animateCounter(el, target) {
        let current = 0;
        const increment = Math.ceil(target / 40) || 1;
        const interval = setInterval(() => {
            current = Math.min(current + increment, target);
            el.textContent = current;
            if (current === target) clearInterval(interval);
        }, 40);
    }
    const counterObserver = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                const el = entry.target;
                const target = parseInt(el.getAttribute('data-target'));
                animateCounter(el, target);
                counterObserver.unobserve(el);
            }
        });
    }, { threshold: 0.5 });
    document.querySelectorAll('[data-target]').forEach(el => counterObserver.observe(el));

    // ACCORDION
    function toggleAccordion(btn) {
        const item = btn.parentElement;
        const isOpen = item.classList.contains('open');
        document.querySelectorAll('.accordion-item').forEach(i => i.classList.remove('open'));
        if (!isOpen) item.classList.add('open');
        lucide.createIcons();
    }

    // NAVBAR E CTA SCROLL
    window.addEventListener('scroll', () => {
        const navbar = document.getElementById('navbar');
        const ctaFloat = document.getElementById('cta-float');
        
        if (window.scrollY > 50) {
            if(navbar) navbar.classList.add('shadow-md');
        } else {
            if(navbar) navbar.classList.remove('shadow-md');
        }

        if (window.scrollY > 400) {
            if(ctaFloat) {
                ctaFloat.classList.remove('hidden', 'opacity-0', 'translate-y-10', 'pointer-events-none');
                ctaFloat.classList.add('opacity-100', 'translate-y-0');
            }
        } else {
            if(ctaFloat) {
                ctaFloat.classList.remove('opacity-100', 'translate-y-0');
                ctaFloat.classList.add('opacity-0', 'translate-y-10', 'pointer-events-none');
            }
        }
    });

    // VIDEO UNMUTE
    document.addEventListener("DOMContentLoaded", function() {
        function setupVideo(videoId, overlayId) {
            const video = document.getElementById(videoId);
            const overlay = document.getElementById(overlayId);
            if (video && overlay) {
                overlay.addEventListener("click", function(e) {
                    e.stopPropagation(); 
                    video.muted = false;
                    video.loop = false; 
                    video.currentTime = 0;
                    video.play();
                    overlay.style.opacity = "0";
                    setTimeout(() => { overlay.style.display = "none"; }, 500); 

                    // Rastreamento Clarity - Vídeo Assistido
                    if (window.clarity) {
                        window.clarity("event", "Video_Assistido_" + videoId);
                    }
                });
                video.addEventListener("click", function() {
                    if (overlay.style.display === "none") {
                        if (video.paused) { video.play(); } else { video.pause(); }
                    }
                });
            }
        }

        setupVideo("vision-video", "unmute-overlay");
        setupVideo("camera-video", "unmute-overlay-camera");
    });
</script>
