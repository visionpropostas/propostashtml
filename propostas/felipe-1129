                        <span class="text-4xl md:text-5xl font-extrabold text-gray-900">R$ ${formatCurrency(val1)}</span>
                    </div>
                    <div class="inline-flex items-center gap-1.5 bg-blue-50 border border-blue-200 text-blue-700 px-3 py-1.5 rounded-full w-fit shadow-sm mt-1 mb-2">
