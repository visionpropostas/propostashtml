            // Start Video Se houver
            const video = document.getElementById("vision-video");
            if (video && video.paused) {
                video.muted = true;
                video.loop = false;
                video.play().catch(e => {});
            }

            // --- CLARITY API TRACKING ---
            if (window.clarity) {
                window.clarity("consent");
                window.clarity("identify", "gabriel-paulista", undefined, undefined, "Gabriel (Escritório Paulista)");
