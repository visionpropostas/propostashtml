    // Multiplicadores da InfinitePay por parcela (True Markup)
    const cardRates = {
        1: 1.0438,  
        2: 1.0560,  
        3: 1.0690,  
        4: 1.0820,  
        5: 1.0940,  
        6: 1.1071,  
        7: 1.1220,  
