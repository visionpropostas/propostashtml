    <script>
        // Inicializa os ícones do Lucide
        lucide.createIcons();

        // Função de alternância de abas/visualizações
        function switchView(view) {
            const viewVisual = document.getElementById('view-visual');
            const viewLista = document.getElementById('view-lista');
            const btnVisual = document.getElementById('btn-visual');
            const btnLista = document.getElementById('btn-lista');

            if (view === 'visual') {
                viewVisual.classList.remove('hidden');
                viewLista.classList.add('hidden');
                
                btnVisual.className = "px-4 py-2 rounded-lg text-sm font-medium transition-all bg-blue-600 text-white shadow-lg shadow-blue-500/10";
                btnLista.className = "px-4 py-2 rounded-lg text-sm font-medium transition-all bg-slate-800 text-slate-300 hover:bg-slate-700";
            } else {
                viewVisual.classList.add('hidden');
                viewLista.classList.remove('hidden');

                btnVisual.className = "px-4 py-2 rounded-lg text-sm font-medium transition-all bg-slate-800 text-slate-300 hover:bg-slate-700";
                btnLista.className = "px-4 py-2 rounded-lg text-sm font-medium transition-all bg-blue-600 text-white shadow-lg shadow-blue-500/10";
            }
        }
    </script>
